<script>
'use strict';
/* ═══════════════════════════════════════════════════════════════════════
   APP STATE
═══════════════════════════════════════════════════════════════════════ */
const S = {
  f: { file: null },
  a: {
    file: null, token: null, filename: null, jobId: null,
    sse: null, sseRetry: 0, pollTimer: null,
    elapsedTimer: null, elapsedSec: 0, done: false,
    logLines: [], // cache all log text for copy
  },
};
const MAX_SSE_RETRY = 6;
const LOG_ICONS = {
  info: '·', step: '▶', found: '★', success: '✔', error: '✖', warn: '⚠',
};

/* ═══════════════════════════════════════════════════════════════════════
   UTILITIES
═══════════════════════════════════════════════════════════════════════ */
// HTML escape
function esc(s) {
  return String(s ?? '')
    .replace(/&/g,'&amp;').replace(/</g,'&lt;')
    .replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}
// Format bytes to human-readable
function fmtSize(bytes) {
  if (!bytes || bytes < 0) return '0 B';
  if (bytes < 1024) return bytes + ' B';
  if (bytes < 1048576) return (bytes/1024).toFixed(1) + ' KB';
  return (bytes/1048576).toFixed(2) + ' MB';
}
// Get current time string
function timeStr() {
  return new Date().toLocaleTimeString('id-ID',{hour12:false,hour:'2-digit',minute:'2-digit',second:'2-digit'});
}
// Clamp a number
function clamp(n, min, max) { return Math.min(max, Math.max(min, n)); }

/* ═══════════════════════════════════════════════════════════════════════
   TOAST
═══════════════════════════════════════════════════════════════════════ */
let _toastTimer = null;
function toast(msg, dur=3200) {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.classList.add('show');
  clearTimeout(_toastTimer);
  _toastTimer = setTimeout(() => el.classList.remove('show'), dur);
}

/* ═══════════════════════════════════════════════════════════════════════
   CONNECTION STATUS
═══════════════════════════════════════════════════════════════════════ */
function setConnStatus(state) {
  const el = document.getElementById('conn-status');
  el.className = '';
  if (state === 'offline')       { el.className='offline'; el.textContent='⚠ Koneksi terputus'; }
  else if (state === 'reconnecting') { el.className='reconnecting'; el.textContent='🔄 Menyambung ulang…'; }
}
window.addEventListener('online',  () => { setConnStatus('ok'); toast('✅ Koneksi kembali'); });
window.addEventListener('offline', () => { setConnStatus('offline'); toast('⚠️ Koneksi terputus!', 5000); });

/* ═══════════════════════════════════════════════════════════════════════
   MODE & TAB SWITCH
═══════════════════════════════════════════════════════════════════════ */
function switchMode(mode, btn) {
  document.querySelectorAll('.mode-tab').forEach(t => {
    t.classList.remove('active');
    t.setAttribute('aria-selected','false');
  });
  document.querySelectorAll('.mode-content').forEach(c => c.classList.remove('active'));
  btn.classList.add('active');
  btn.setAttribute('aria-selected','true');
  document.getElementById('mode-' + mode).classList.add('active');
  document.getElementById('tool').scrollIntoView({behavior:'smooth',block:'start'});
}

function switchTab(btn, id) {
  const card = btn.closest('.tool-card');
  card.querySelectorAll('.tab-btn').forEach(b => { b.classList.remove('active'); b.setAttribute('aria-selected','false'); });
  card.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
  btn.classList.add('active');
  btn.setAttribute('aria-selected','true');
  document.getElementById(id).classList.add('active');
}

/* ═══════════════════════════════════════════════════════════════════════
   DRAG & DROP
═══════════════════════════════════════════════════════════════════════ */
function dzOver(el, e) {
  e.preventDefault(); e.stopPropagation();
  el.classList.add('over');
}
function dzLeave(el) { el.classList.remove('over'); }
function dzDrop(el, e, mode) {
  e.preventDefault(); e.stopPropagation();
  el.classList.remove('over');
  const f = e.dataTransfer?.files?.[0];
  if (f) setFile(mode, f);
}

/* ═══════════════════════════════════════════════════════════════════════
   FILE VALIDATION & SELECTION
═══════════════════════════════════════════════════════════════════════ */
const FILE_RULES = {
  f: { ext: /\.(so|bin)$/i,                      maxMB: 150, label: '.so / .bin' },
  a: { ext: /\.(apk|xapk|apkm|apks)$/i,          maxMB: 500, label: '.apk / .xapk / .apkm / .apks' },
};

function onPick(input, mode) {
  if (input.files?.[0]) setFile(mode, input.files[0]);
}

function setFile(mode, file) {
  const rule = FILE_RULES[mode];
  // Validate extension
  if (!rule.ext.test(file.name)) {
    const ext = file.name.split('.').pop().toUpperCase() || 'unknown';
    toast(`⚠️ Format .${ext} tidak didukung. Harus ${rule.label}`, 4000);
    return;
  }
  // Validate size
  if (file.size > rule.maxMB * 1048576) {
    toast(`⚠️ File terlalu besar! Maksimum ${rule.maxMB} MB`, 4000);
    return;
  }
  // Validate not zero-byte
  if (file.size === 0) {
    toast('⚠️ File kosong (0 byte). Pilih file yang valid.', 4000);
    return;
  }

  S[mode].file = file;

  // Update dropzone visual
  const dz = document.getElementById('dz-' + mode);
  if (dz) dz.classList.add('has-file');

  // Show file preview
  const fp   = document.getElementById('fp-' + mode);
  const name = document.getElementById('fp-' + mode + '-name');
  const meta = document.getElementById('fp-' + mode + '-meta');
  name.textContent = file.name;
  meta.textContent = `${fmtSize(file.size)} · ${file.lastModifiedDate ? new Date(file.lastModified).toLocaleDateString('id-ID') : 'baru dipilih'}`;
  fp.classList.add('show');

  if (mode === 'f') {
    document.getElementById('btn-f').disabled = false;
    resetFlutterResult();
  } else {
    S.a.token = null; S.a.filename = null;
    document.getElementById('btn-scan').disabled = false;
    document.getElementById('scan-res').classList.remove('show');
    lockStep2(true); lockStep3(true);
  }
}

function clearFile(mode) {
  S[mode].file = null;
  document.getElementById('fp-' + mode).classList.remove('show');
  const inp = document.getElementById('file-' + mode);
  if (inp) inp.value = '';

  const dz = document.getElementById('dz-' + mode);
  if (dz) dz.classList.remove('has-file');

  if (mode === 'f') {
    document.getElementById('btn-f').disabled = true;
    resetFlutterResult();
  } else {
    document.getElementById('btn-scan').disabled = true;
    S.a.token = null;
    document.getElementById('scan-res').classList.remove('show');
    lockStep2(true); lockStep3(true);
  }
}

/* ═══════════════════════════════════════════════════════════════════════
   RESET FLUTTER RESULT AREA
═══════════════════════════════════════════════════════════════════════ */
function resetFlutterResult() {
  clearLog('f');
  const r = document.getElementById('result-f');
  r.innerHTML = ''; r.classList.remove('show');
  document.getElementById('log-f').classList.remove('show');
  document.getElementById('prog-f').classList.remove('show');
  document.getElementById('up-prog-f').classList.remove('show');
  setLiveDot('f', false);
}

/* ═══════════════════════════════════════════════════════════════════════
   LIVE DOT INDICATOR
═══════════════════════════════════════════════════════════════════════ */
function setLiveDot(mode, active) {
  const dot = document.getElementById('log-' + mode + '-dot');
  if (!dot) return;
  if (active) dot.classList.remove('stopped');
  else        dot.classList.add('stopped');
}

/* ═══════════════════════════════════════════════════════════════════════
   LOG HELPERS
═══════════════════════════════════════════════════════════════════════ */
const logCounts = { f: 0, a: 0 };

function addLog(mode, entry) {
  if (!entry || typeof entry !== 'object' || !entry.text) return;

  const body  = document.getElementById('log-' + mode + '-body');
  const panel = document.getElementById('log-' + mode);
  if (!body || !panel) return;

  panel.classList.add('show');
  setLiveDot(mode, true);

  const validLevels = ['info','step','found','success','error','warn'];
  const lvl = validLevels.includes(entry.level) ? entry.level : 'info';

  const line = document.createElement('div');
  line.className = `log-line lv-${lvl} new`;
  const ts  = timeStr();
  const ico = LOG_ICONS[lvl] || '·';
  line.innerHTML = `<span class="log-ts">[${esc(ts)}]</span><span class="log-ico">${ico}</span><span class="log-txt">${esc(String(entry.text))}</span>`;
  body.appendChild(line);

  // Remove animation class after it plays
  line.addEventListener('animationend', () => line.classList.remove('new'), {once:true});

  logCounts[mode]++;
  const cntEl = document.getElementById('log-' + mode + '-cnt');
  if (cntEl) cntEl.textContent = logCounts[mode];

  // Cache for copy
  if (mode === 'a') S.a.logLines.push(`[${ts}] ${ico} ${entry.text}`);

  // Auto-scroll: only if user is within 100px of bottom
  const nearBottom = body.scrollHeight - body.scrollTop - body.clientHeight < 100;
  if (nearBottom) requestAnimationFrame(() => { body.scrollTop = body.scrollHeight; });
}

function scrollLog(mode) {
  const body = document.getElementById('log-' + mode + '-body');
  if (body) body.scrollTo({top: body.scrollHeight, behavior:'smooth'});
}

function clearLog(mode) {
  logCounts[mode] = 0;
  const cntEl = document.getElementById('log-' + mode + '-cnt');
  if (cntEl) cntEl.textContent = '0';
  const body = document.getElementById('log-' + mode + '-body');
  if (body) body.innerHTML = '';
  if (mode === 'a') S.a.logLines = [];
  setLiveDot(mode, false);
}

function copyLog(mode) {
  const text = S[mode]?.logLines?.join('\n') || '';
  if (!text) { toast('Log kosong'); return; }
  navigator.clipboard?.writeText(text)
    .then(() => toast('✅ Log disalin ke clipboard'))
    .catch(() => toast('❌ Gagal menyalin log'));
}

/* ═══════════════════════════════════════════════════════════════════════
   PROGRESS BAR
═══════════════════════════════════════════════════════════════════════ */
function setProgress(mode, pct, label, state='') {
  const wrap  = document.getElementById('prog-' + mode);
  const fill  = document.getElementById('prog-' + mode + '-fill');
  const lbl   = document.getElementById('prog-' + mode + '-lbl');
  const pctEl = document.getElementById('prog-' + mode + '-pct');
  if (!wrap) return;
  wrap.classList.add('show');
  const pv = clamp(pct, 0, 100);
  fill.style.width = pv + '%';
  fill.className = 'prog-fill' + (state ? ' ' + state : '');
  fill.setAttribute('aria-valuenow', pv);
  if (label && lbl) lbl.textContent = label;
  if (pctEl) pctEl.textContent = pct >= 0 ? pct + '%' : '';
}

/* ═══════════════════════════════════════════════════════════════════════
   UPLOAD PROGRESS
═══════════════════════════════════════════════════════════════════════ */
function setUploadProgress(mode, pct) {
  const wrap  = document.getElementById('up-prog-' + mode);
  const fill  = document.getElementById('up-fill-' + mode);
  const pctEl = document.getElementById('up-pct-' + mode);
  if (!wrap) return;
  wrap.classList.add('show');
  fill.style.width = pct + '%';
  if (pctEl) pctEl.textContent = pct + '%';
  if (pct >= 100) {
    setTimeout(() => { if (wrap) wrap.classList.remove('show'); }, 800);
  }
}

/* ═══════════════════════════════════════════════════════════════════════
   XHR WITH UPLOAD PROGRESS (for real upload progress bar)
═══════════════════════════════════════════════════════════════════════ */
function xhrPost(url, formData, onProgress, timeoutMs=600000) {
  return new Promise((resolve, reject) => {
    const xhr = new XMLHttpRequest();
    xhr.open('POST', url);
    if (onProgress) {
      xhr.upload.addEventListener('progress', (e) => {
        if (e.lengthComputable) onProgress(Math.round(e.loaded / e.total * 100));
      });
    }
    xhr.onload = () => {
      if (xhr.status >= 200 && xhr.status < 300) {
        try { resolve(JSON.parse(xhr.responseText)); }
        catch { reject(new Error(`Server error: response tidak bisa di-parse (HTTP ${xhr.status})`)); }
      } else {
        let errMsg = `Server error HTTP ${xhr.status}`;
        try {
          const errData = JSON.parse(xhr.responseText);
          if (errData?.error) errMsg = errData.error;
        } catch {}
        reject(new Error(errMsg));
      }
    };
    xhr.onerror   = () => reject(new Error('Network error — tidak bisa terhubung ke server. Periksa koneksi internet.'));
    xhr.ontimeout = () => reject(new Error('Request timeout — file terlalu besar atau koneksi lambat.'));
    xhr.timeout   = timeoutMs;
    xhr.send(formData);
  });
}

/* ═══════════════════════════════════════════════════════════════════════
   FLUTTER SSL PATCH
═══════════════════════════════════════════════════════════════════════ */
async function runFlutterPatch() {
  const file = S.f.file;
  if (!file) { toast('⚠️ Pilih file dulu!'); return; }

  const btn = document.getElementById('btn-f');
  btn.disabled = true;
  btn.classList.add('loading');
  resetFlutterResult();

  addLog('f', {level:'step', text:'Memulai Flutter SSL Patch…'});
  addLog('f', {level:'info', text:`File: ${file.name} (${fmtSize(file.size)})`});
  setProgress('f', 5, 'Mengupload file…');

  const fd = new FormData();
  fd.append('file', file);
  fd.append('arch', document.getElementById('arch-f').value);
  fd.append('printOnly', document.getElementById('print-f').checked ? 'true' : 'false');

  try {
    setUploadProgress('f', 0);
    const data = await xhrPost('/api/patch', fd, (pct) => {
      setUploadProgress('f', pct);
      setProgress('f', 5 + Math.round(pct * 0.45), `Mengupload… ${pct}%`);
    });

    setUploadProgress('f', 100);
    setProgress('f', 65, 'Menganalisis binary…');

    if (!data || typeof data !== 'object') throw new Error('Respons server tidak valid');
    if (data.error) throw new Error(data.error);

    // Replay server log entries
    (data.log || []).forEach(e => addLog('f', e));

    setProgress('f', 100, data.success ? 'Selesai!' : 'Gagal!', data.success ? 'done' : 'error');
    setLiveDot('f', false);
    renderFlutterResult(data);

  } catch (err) {
    const msg = err.message || 'Terjadi kesalahan tidak dikenal';
    addLog('f', {level:'error', text:`❌ Error: ${msg}`});
    setProgress('f', 100, 'Error!', 'error');
    setLiveDot('f', false);
    renderFlutterResult({success:false, _clientError:msg});
    console.error('[runFlutterPatch]', err);
  } finally {
    btn.disabled = false;
    btn.classList.remove('loading');
  }
}

function renderFlutterResult(data) {
  const el = document.getElementById('result-f');
  el.classList.add('show');

  if (!data.success) {
    const reason = data._clientError || 'ssl_verify_peer_cert tidak ditemukan di binary ini.';
    el.innerHTML = `
      <div class="res-err">
        <div class="res-head">
          <div class="res-ico res-ico-err" aria-hidden="true">❌</div>
          <div>
            <div class="res-t">Patch Gagal</div>
            <div class="res-s">${esc(reason)}</div>
          </div>
        </div>
        <div class="alert alert-w" style="margin-top:.7rem">
          <span class="alert-ico" aria-hidden="true">💡</span>
          <div>Coba mode <strong>APK Patcher</strong> untuk bypass SSL via Smali, atau pastikan file adalah <code>libflutter.so</code> yang valid dan belum di-obfuscate. Coba juga pilih architecture secara manual.</div>
        </div>
      </div>`;
    toast('❌ Patch gagal. Lihat log untuk detail.', 4500);
    return;
  }

  const m = data.meta || {};

  if (data.printOnly) {
    el.innerHTML = `
      <div class="res-ok">
        <div class="res-head">
          <div class="res-ico res-ico-ok" aria-hidden="true">🔍</div>
          <div>
            <div class="res-t">Print Only — Offset Ditemukan!</div>
            <div class="res-s">ssl_verify_peer_cert berhasil diidentifikasi. File tidak diubah.</div>
          </div>
        </div>
        <div class="meta-grid">
          <div class="mi"><div class="mi-l">Architecture</div><div class="mi-v">${esc(m.arch||'—')}</div></div>
          <div class="mi"><div class="mi-l">Pattern</div><div class="mi-v">#${esc(String(m.patternIdx||'—'))}</div></div>
          <div class="mi"><div class="mi-l">Found Offset</div><div class="mi-v">${esc(m.foundOffset||'—')}</div></div>
          <div class="mi"><div class="mi-l">Fn Start</div><div class="mi-v">${esc(m.fnOffset||'—')}</div></div>
        </div>
        <div class="res-actions">
          <button class="btn-sec" onclick="document.getElementById('print-f').checked=false;runFlutterPatch()">⚡ Patch &amp; Download</button>
          <button class="btn-sec" onclick="clearFile('f')">🔄 File Lain</button>
        </div>
      </div>`;
    toast('🔍 Offset ditemukan!', 3500);
    return;
  }

  el.innerHTML = `
    <div class="res-ok">
      <div class="res-head">
        <div class="res-ico res-ico-ok" aria-hidden="true">✅</div>
        <div>
          <div class="res-t">Patch Berhasil!</div>
          <div class="res-s">ssl_verify_peer_cert di-overwrite dengan ret0. SSL verification dinonaktifkan.</div>
        </div>
      </div>
      <div class="meta-grid">
        <div class="mi"><div class="mi-l">Architecture</div><div class="mi-v">${esc(m.arch||'—')}</div></div>
        <div class="mi"><div class="mi-l">Pattern</div><div class="mi-v">#${esc(String(m.patternIdx||'—'))}</div></div>
        <div class="mi"><div class="mi-l">Found Offset</div><div class="mi-v">${esc(m.foundOffset||'—')}</div></div>
        <div class="mi"><div class="mi-l">Fn Start</div><div class="mi-v">${esc(m.fnOffset||'—')}</div></div>
        <div class="mi"><div class="mi-l">File Size</div><div class="mi-v">${fmtSize(data.sizeBytes||0)}</div></div>
        <div class="mi"><div class="mi-l">Original Bytes</div><div class="mi-v" style="font-size:.68rem">${esc(m.originalBytes||'—')}</div></div>
        <div class="mi" style="border-color:rgba(16,185,129,.2)"><div class="mi-l">Patched Bytes</div><div class="mi-v" style="font-size:.68rem;color:var(--g2)">${esc(m.patchedBytes||'—')}</div></div>
      </div>
      <div class="res-actions">
        <a class="btn-dl" href="/api/download/${esc(data.downloadId)}"
           download="${esc(data.filename||'patched.so')}"
           aria-label="Download ${esc(data.filename||'patched.so')}">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/></svg>
          Download ${esc(data.filename||'patched.so')}
        </a>
        <button class="btn-sec" onclick="clearFile('f')">🔄 Patch File Lain</button>
      </div>
      <div class="alert alert-i" style="margin-top:.7rem">
        <span class="alert-ico" aria-hidden="true">📱</span>
        <div>Ganti <code>libflutter.so</code> di dalam APK, lalu re-sign dan install. Intercept traffic dengan Burp Suite / mitmproxy.</div>
      </div>
    </div>`;
  toast('✅ Patch berhasil! Siap didownload.', 5000);
}

/* ═══════════════════════════════════════════════════════════════════════
   APK SCAN
═══════════════════════════════════════════════════════════════════════ */
async function scanApk() {
  const file = S.a.file;
  if (!file) { toast('⚠️ Pilih APK dulu!'); return; }

  const btn = document.getElementById('btn-scan');
  btn.disabled = true;
  btn.classList.add('loading');
  document.getElementById('scan-res').classList.remove('show');

  const fd = new FormData();
  fd.append('file', file);

  try {
    setUploadProgress('a', 0);
    const data = await xhrPost('/api/apk/scan', fd, (pct) => {
      setUploadProgress('a', pct);
    });
    setUploadProgress('a', 100);

    if (!data?.success) throw new Error(data?.error || 'Scan gagal tanpa pesan error');

    S.a.token    = data.token;
    S.a.filename = data.filename;

    // Render scan result badges
    const chips = document.getElementById('scan-chips');
    chips.innerHTML = '';
    const addChip = (txt, cls) => {
      const b = document.createElement('span');
      b.className = 'chip ' + cls;
      b.textContent = txt;
      chips.appendChild(b);
    };
    addChip('📄 ' + (data.filename || 'unknown'), 'ch-b');
    addChip('📦 ' + fmtSize(data.size || 0), 'ch-p');
    if (data.files)   addChip(`🗂 ${data.files} file`, 'ch-c');
    if (data.pkg)     addChip('📛 ' + data.pkg, 'ch-y');
    addChip(data.flutter ? '✅ Flutter detected' : '❌ No Flutter lib', data.flutter ? 'ch-g' : 'ch-o');
    if (data.pairip)  addChip('⚠️ Pairip detected', 'ch-o');
    if (data.error)   addChip('⚠️ ' + data.error, 'ch-y');

    document.getElementById('scan-res').classList.add('show');

    // Auto-check flutter SSL if detected
    if (data.flutter) {
      const ck = document.getElementById('ck-flutter');
      if (ck && !ck.checked) { ck.checked = true; syncPopt(ck); }
    }

    // Unlock step 2
    lockStep2(false);
    document.getElementById('snum-1').classList.add('done-num');

    // Smooth scroll to step 2
    setTimeout(() => {
      const s2 = document.getElementById('step2-wrap');
      if (s2) s2.scrollIntoView({behavior:'smooth', block:'nearest'});
    }, 350);

    toast('✅ Scan selesai!');
  } catch (err) {
    const msg = err.message || 'Scan gagal';
    toast('❌ ' + msg, 4500);
    console.error('[scanApk]', err);
  } finally {
    btn.disabled = false;
    btn.classList.remove('loading');
  }
}

/* ═══════════════════════════════════════════════════════════════════════
   PATCH OPTION SYNC (toggle card style)
═══════════════════════════════════════════════════════════════════════ */
function syncPopt(chk) {
  const label = chk.closest('.popt');
  if (label) label.classList.toggle('on', chk.checked);
  // Enable patch button only if any option is checked
  const KEYS = ['flutter','pairip','pairip_corex','spoof_pkg','remove_ads',
                 'remove_ss','remove_usb','random_info','purchase','tg_patch'];
  const anyOn = KEYS.some(k => document.getElementById('ck-' + k)?.checked);
  const btn = document.getElementById('btn-patch-apk');
  if (btn) btn.disabled = !anyOn;
}

/* ═══════════════════════════════════════════════════════════════════════
   STEP LOCK/UNLOCK
═══════════════════════════════════════════════════════════════════════ */
function lockStep2(locked) {
  const wrap = document.getElementById('step2-wrap');
  const sc   = document.getElementById('sc-2');
  if (!wrap || !sc) return;
  wrap.style.opacity       = locked ? '.35' : '1';
  wrap.style.pointerEvents = locked ? 'none' : 'auto';
  wrap.setAttribute('aria-disabled', locked ? 'true' : 'false');
  sc.classList.toggle('open', !locked);
  if (!locked) {
    // Reset patch button — re-check via syncPopt
    const btn = document.getElementById('btn-patch-apk');
    if (btn) btn.disabled = true;
  }
}

function lockStep3(locked) {
  const wrap = document.getElementById('step3-wrap');
  const sc   = document.getElementById('sc-3');
  if (!wrap || !sc) return;
  wrap.style.opacity       = locked ? '.35' : '1';
  wrap.style.pointerEvents = locked ? 'none' : 'auto';
  wrap.setAttribute('aria-disabled', locked ? 'true' : 'false');
  sc.classList.toggle('open', !locked);
}

/* ═══════════════════════════════════════════════════════════════════════
   APK PATCH (start job)
═══════════════════════════════════════════════════════════════════════ */
async function runApkPatch() {
  if (!S.a.token) { toast('⚠️ Scan APK dulu di Step 1!'); return; }

  // Collect options
  const KEYS = ['flutter','pairip','pairip_corex','spoof_pkg','remove_ads',
                 'remove_ss','remove_usb','random_info','purchase','tg_patch'];
  const options = {};
  KEYS.forEach(k => { options[k] = document.getElementById('ck-' + k)?.checked || false; });

  // Validate android ID if provided
  const aid = (document.getElementById('aid-inp')?.value || '').trim();
  if (aid) {
    if (!/^[a-fA-F0-9]{16}$/.test(aid)) {
      toast('⚠️ Android ID harus tepat 16 karakter hex!', 4000);
      document.getElementById('aid-inp').focus();
      return;
    }
    options.android_id = aid;
  }

  // At least one patch must be selected
  if (!KEYS.some(k => options[k])) {
    toast('⚠️ Pilih minimal satu patch!', 3500);
    return;
  }

  const btn = document.getElementById('btn-patch-apk');
  btn.disabled = true;
  btn.classList.add('loading');

  // Show step 3
  lockStep3(false);
  document.getElementById('snum-2').classList.add('done-num');
  clearLog('a');
  S.a.logLines = [];
  const rA = document.getElementById('result-a');
  rA.innerHTML = ''; rA.classList.remove('show');
  document.getElementById('apk-reset-row').classList.add('hidden');

  // Reset job UI
  const pill = document.getElementById('job-pill');
  if (pill) { pill.className='status-pill sp-run sp-pulse'; pill.textContent='⏳ Menjalankan ApkPatcher…'; }
  setProgress('a', 3, 'Memulai job…');
  S.a.done = false;
  startElapsed();

  // Scroll to step 3
  setTimeout(() => {
    const s3 = document.getElementById('step3-wrap');
    if (s3) s3.scrollIntoView({behavior:'smooth', block:'nearest'});
  }, 320);

  try {
    const resp = await fetch('/api/apk/patch', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({token: S.a.token, filename: S.a.filename, options}),
      signal: AbortSignal.timeout(30000), // 30s for job start
    });
    if (!resp.ok) {
      const errData = await resp.json().catch(() => ({}));
      throw new Error(errData?.error || `Server error HTTP ${resp.status}`);
    }
    const data = await resp.json().catch(() => ({}));
    if (!data?.success) throw new Error(data?.error || 'Gagal memulai job');

    S.a.jobId = data.jobId;
    connectSSE(data.jobId);

  } catch (err) {
    const msg = err.message || 'Gagal memulai patch';
    addLog('a', {level:'error', text:'❌ Gagal memulai: ' + msg});
    setProgress('a', 100, 'Error!', 'error');
    setLiveDot('a', false);
    stopElapsed();
    document.getElementById('apk-reset-row').classList.remove('hidden');
    btn.disabled = false;
    btn.classList.remove('loading');
    toast('❌ ' + msg, 4500);
    console.error('[runApkPatch]', err);
  }
}

/* ═══════════════════════════════════════════════════════════════════════
   ELAPSED TIMER
═══════════════════════════════════════════════════════════════════════ */
function startElapsed() {
  stopElapsed();
  S.a.elapsedSec = 0;
  S.a.elapsedTimer = setInterval(() => {
    S.a.elapsedSec++;
    const m = Math.floor(S.a.elapsedSec / 60);
    const s = S.a.elapsedSec % 60;
    const el = document.getElementById('job-elapsed');
    if (el) el.textContent = `${m > 0 ? m + 'm ' : ''}${String(s).padStart(2,'0')}s berlalu`;
  }, 1000);
}

function stopElapsed() {
  if (S.a.elapsedTimer) { clearInterval(S.a.elapsedTimer); S.a.elapsedTimer = null; }
}

/* ═══════════════════════════════════════════════════════════════════════
   SSE CONNECTION — Real-time live log streaming
═══════════════════════════════════════════════════════════════════════ */
function connectSSE(jobId) {
  if (S.a.sse) { try { S.a.sse.close(); } catch {} S.a.sse = null; }
  S.a.sseRetry = 0;
  _openSSE(jobId);
}

function _openSSE(jobId) {
  setConnStatus('ok');
  const sse = new EventSource(`/api/apk/status/${jobId}`);
  S.a.sse = sse;

  let logBuf = 0; // log line counter for progress estimation

  sse.onmessage = (e) => {
    let entry;
    try { entry = JSON.parse(e.data); } catch { return; }

    if (entry.level === '__ping__') return; // keep-alive heartbeat

    if (entry.level === '__done__') {
      sse.close(); S.a.sse = null;
      stopElapsed();
      setConnStatus('ok');
      setLiveDot('a', false);
      S.a.done = true;

      const pill = document.getElementById('job-pill');
      if (pill) {
        pill.className = entry.success ? 'status-pill sp-ok' : 'status-pill sp-err';
        pill.textContent = entry.success ? '✅ Selesai' : '❌ Gagal';
      }
      setProgress('a', 100, entry.success ? 'Selesai!' : 'Gagal!', entry.success ? 'done' : 'error');
      renderApkResult(entry);
      document.getElementById('apk-reset-row').classList.remove('hidden');
      const btn = document.getElementById('btn-patch-apk');
      if (btn) btn.classList.remove('loading');
      return;
    }

    if (entry.level && entry.text) {
      addLog('a', entry);
      logBuf++;

      // Progress: 5% → 90% based on log volume + keyword detection
      const pct = clamp(5 + logBuf * 1.8, 5, 90);
      const low = entry.text.toLowerCase();
      let lbl = 'Memproses…';
      if (/decompil/i.test(low))                   lbl = '📂 Decompiling APK…';
      else if (/smali|patch/i.test(low))           lbl = '🔧 Patching Smali…';
      else if (/recompil|build|compil/i.test(low)) lbl = '🔨 Recompiling…';
      else if (/sign|apksigner/i.test(low))        lbl = '✒️ Signing APK…';
      else if (/flutter|ssl/i.test(low))           lbl = '⚡ Flutter SSL Patch…';
      setProgress('a', Math.round(pct), lbl);
    }
  };

  sse.onerror = () => {
    sse.close(); S.a.sse = null;
    if (S.a.done) return;

    S.a.sseRetry++;
    if (S.a.sseRetry > MAX_SSE_RETRY) {
      setConnStatus('offline');
      addLog('a', {level:'warn', text:`SSE gagal ${MAX_SSE_RETRY}x. Beralih ke mode polling…`});
      _startPolling(jobId);
      return;
    }
    setConnStatus('reconnecting');
    const delay = Math.min(1200 * S.a.sseRetry, 10000);
    addLog('a', {level:'warn', text:`Koneksi terputus. Menyambung ulang dalam ${(delay/1000).toFixed(1)}s… (${S.a.sseRetry}/${MAX_SSE_RETRY})`});
    setTimeout(() => { if (!S.a.done) _openSSE(jobId); }, delay);
  };
}

/* ═══════════════════════════════════════════════════════════════════════
   POLLING FALLBACK (when SSE fails)
═══════════════════════════════════════════════════════════════════════ */
function _startPolling(jobId) {
  if (S.a.pollTimer) { clearInterval(S.a.pollTimer); S.a.pollTimer = null; }
  let lastCount = 0;
  let pollFails = 0;
  const MAX_POLL_FAIL = 10;

  const poll = async () => {
    if (S.a.done) { clearInterval(S.a.pollTimer); return; }
    try {
      const r = await fetch(`/api/apk/job/${jobId}`, {signal: AbortSignal.timeout(8000)});
      if (!r.ok) throw new Error(`HTTP ${r.status}`);
      const d = await r.json();
      pollFails = 0; // reset on success

      if (d.logs && d.logs.length > lastCount) {
        const newEntries = d.logs.slice(lastCount);
        newEntries.forEach(e => { if (e.level && e.text) addLog('a', e); });
        lastCount = d.logs.length;
        setProgress('a', clamp(5 + lastCount * 1.8, 5, 90), 'Memproses (polling)…');
      }

      if (d.done) {
        clearInterval(S.a.pollTimer); S.a.pollTimer = null;
        stopElapsed(); S.a.done = true;
        setConnStatus('ok');
        setLiveDot('a', false);
        setProgress('a', 100, d.success ? 'Selesai!' : 'Gagal!', d.success ? 'done' : 'error');
        renderApkResult({success: d.success, downloadId: d.downloadId, filename: d.filename});
        document.getElementById('apk-reset-row').classList.remove('hidden');
        const btn = document.getElementById('btn-patch-apk');
        if (btn) btn.classList.remove('loading');
      }
    } catch (err) {
      pollFails++;
      if (pollFails >= MAX_POLL_FAIL) {
        clearInterval(S.a.pollTimer);
        addLog('a', {level:'error', text:'Koneksi ke server gagal berulang kali. Refresh halaman dan coba lagi.'});
        toast('❌ Koneksi gagal. Silakan refresh.', 6000);
      }
    }
  };

  S.a.pollTimer = setInterval(poll, 3000);
  poll(); // immediate first poll
}

/* ═══════════════════════════════════════════════════════════════════════
   RENDER APK RESULT
═══════════════════════════════════════════════════════════════════════ */
function renderApkResult(data) {
  const el = document.getElementById('result-a');
  if (!el) return;
  el.classList.add('show');
  document.getElementById('snum-3').classList.add('done-num');

  if (!data.success) {
    el.innerHTML = `
      <div class="res-err">
        <div class="res-head">
          <div class="res-ico res-ico-err" aria-hidden="true">❌</div>
          <div>
            <div class="res-t">Patch Gagal</div>
            <div class="res-s">Lihat log di atas untuk detail error.</div>
          </div>
        </div>
        <div class="alert alert-i" style="margin-top:.7rem">
          <span class="alert-ico" aria-hidden="true">💡</span>
          <div>Tips: Pastikan APK valid dan tidak terkorupsi. Coba deselect patch yang mungkin tidak kompatibel (misal: Flutter SSL jika APK bukan Flutter app). Beberapa APK memerlukan Java yang kompatibel.</div>
        </div>
      </div>`;
    toast('❌ Patch gagal. Lihat log untuk detail.', 5000);
    return;
  }

  el.innerHTML = `
    <div class="res-ok">
      <div class="res-head">
        <div class="res-ico res-ico-ok" aria-hidden="true">✅</div>
        <div>
          <div class="res-t">APK Berhasil Di-Patch!</div>
          <div class="res-s">APK telah di-patch, di-sign &amp; siap didownload. <strong>Link expired dalam 30 menit.</strong></div>
        </div>
      </div>
      <div class="res-actions">
        <a class="btn-dl" href="/api/apk/download/${esc(data.downloadId)}"
           download="${esc(data.filename||'patched.apk')}"
           aria-label="Download ${esc(data.filename||'patched.apk')}">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/></svg>
          Download ${esc(data.filename||'patched.apk')}
        </a>
      </div>
      <div class="alert alert-w" style="margin-top:.7rem">
        <span class="alert-ico" aria-hidden="true">📱</span>
        <div>Install APK di perangkat Android. Jika ada proteksi Pairip: install di VM/Multi-App. Untuk Flutter SSL: intercept traffic dengan Burp Suite / mitmproxy.</div>
      </div>
    </div>`;
  toast('✅ APK berhasil di-patch! Segera download sebelum expired.', 6000);
}

/* ═══════════════════════════════════════════════════════════════════════
   RESET APK PATCHER (back to step 1)
═══════════════════════════════════════════════════════════════════════ */
function resetApk() {
  // Close SSE / polling
  if (S.a.sse) { try { S.a.sse.close(); } catch {} S.a.sse = null; }
  if (S.a.pollTimer) { clearInterval(S.a.pollTimer); S.a.pollTimer = null; }
  stopElapsed();

  // Reset state
  S.a = {
    file:null, token:null, filename:null, jobId:null,
    sse:null, sseRetry:0, pollTimer:null,
    elapsedTimer:null, elapsedSec:0, done:false, logLines:[],
  };

  // Reset UI
  clearFile('a');
  document.getElementById('scan-res').classList.remove('show');
  lockStep2(true); lockStep3(true);
  clearLog('a');

  const rA = document.getElementById('result-a');
  if (rA) { rA.innerHTML = ''; rA.classList.remove('show'); }

  const prog = document.getElementById('prog-a');
  if (prog) prog.classList.remove('show');
  const progFill = document.getElementById('prog-a-fill');
  if (progFill) { progFill.style.width='3%'; progFill.className='prog-fill'; }

  document.getElementById('apk-reset-row').classList.add('hidden');

  const pill = document.getElementById('job-pill');
  if (pill) { pill.className='status-pill sp-run sp-pulse'; pill.textContent='⏳ Menjalankan ApkPatcher…'; }
  const elapsed = document.getElementById('job-elapsed');
  if (elapsed) elapsed.textContent = '';

  document.getElementById('snum-1').classList.remove('done-num');
  document.getElementById('snum-2').classList.remove('done-num');
  document.getElementById('snum-3').classList.remove('done-num');

  const btn = document.getElementById('btn-patch-apk');
  if (btn) btn.classList.remove('loading');

  // Uncheck all patch options
  ['flutter','pairip','pairip_corex','spoof_pkg','remove_ads',
   'remove_ss','remove_usb','random_info','purchase','tg_patch'].forEach(k => {
    const ck = document.getElementById('ck-' + k);
    if (ck) { ck.checked = false; const lbl = ck.closest('.popt'); if (lbl) lbl.classList.remove('on'); }
  });
  const aid = document.getElementById('aid-inp');
  if (aid) aid.value = '';

  setConnStatus('ok');

  // Scroll to top of tool
  window.scrollTo({top: (document.getElementById('tool')?.offsetTop||0) - 64, behavior:'smooth'});
}

/* ═══════════════════════════════════════════════════════════════════════
   CLIPBOARD PASTE support (Ctrl+V / Cmd+V)
═══════════════════════════════════════════════════════════════════════ */
document.addEventListener('paste', (e) => {
  // Don't intercept paste in input fields
  if (['INPUT','TEXTAREA'].includes(e.target?.tagName)) return;
  const files = e.clipboardData?.files;
  if (!files?.length) return;
  const f = files[0];
  if (/\.(so|bin)$/i.test(f.name))           setFile('f', f);
  else if (/\.(apk|xapk|apkm|apks)$/i.test(f.name)) setFile('a', f);
});

/* ═══════════════════════════════════════════════════════════════════════
   COPY CODE BLOCKS
═══════════════════════════════════════════════════════════════════════ */
function cpCode(btn) {
  const code = btn.closest('.code-blk')?.querySelector('code');
  if (!code) return;
  navigator.clipboard?.writeText(code.textContent.trim())
    .then(() => {
      btn.textContent = '✓ Copied!';
      btn.classList.add('ok');
      setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('ok'); }, 1800);
    })
    .catch(() => toast('❌ Clipboard access denied'));
}

/* ═══════════════════════════════════════════════════════════════════════
   KEYBOARD SHORTCUTS
═══════════════════════════════════════════════════════════════════════ */
document.addEventListener('keydown', (e) => {
  // No shortcut when typing in inputs
  if (['INPUT','TEXTAREA','SELECT'].includes(e.target?.tagName)) return;
  // Tab 1/2 via keyboard
  if (e.key === '1' && !e.ctrlKey && !e.metaKey) {
    switchMode('flutter', document.getElementById('tab-flutter'));
  } else if (e.key === '2' && !e.ctrlKey && !e.metaKey) {
    switchMode('apk', document.getElementById('tab-apk'));
  }
});

/* ═══════════════════════════════════════════════════════════════════════
   INITIALIZATION
═══════════════════════════════════════════════════════════════════════ */
window.addEventListener('DOMContentLoaded', async () => {
  // Open step 1 content for APK mode by default
  const sc1 = document.getElementById('sc-1');
  if (sc1) sc1.classList.add('open');

  // Health check — update status dots
  try {
    const ctrl = new AbortController();
    const timer = setTimeout(() => ctrl.abort(), 6000);
    const r = await fetch('/api/health', {signal: ctrl.signal});
    clearTimeout(timer);
    const d = await r.json();
    // Update status indicators
    ['srv-status-f','srv-status-a'].forEach(id => {
      const el = document.getElementById(id);
      if (el) { el.textContent = 'Online'; el.style.color = 'var(--g2)'; }
    });
    console.log(`✅ APK Patch Suite ${d.version} | Node ${d.node} | uptime ${d.uptime}s`);
    if (!d.tools?.java || !d.tools?.apktool) {
      console.warn('⚠️ Some tools missing:', d.tools);
    }
  } catch (e) {
    ['srv-status-f','srv-status-a'].forEach(id => {
      const el = document.getElementById(id);
      if (el) { el.textContent = 'Offline'; el.style.color = 'var(--r2)'; }
    });
    console.warn('Health check failed:', e.message);
  }
});

/* ═══════════════════════════════════════════════════════════════════════
   BEFORE UNLOAD — warn if APK job is running
═══════════════════════════════════════════════════════════════════════ */
window.addEventListener('beforeunload', (e) => {
  if (S.a.jobId && !S.a.done) {
    e.preventDefault();
    e.returnValue = 'Proses APK Patcher sedang berjalan. Yakin ingin meninggalkan halaman?';
    return e.returnValue;
  }
});
</script>
</body>
</html>
