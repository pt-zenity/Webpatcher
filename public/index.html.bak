<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover"/>
<meta name="theme-color" content="#07090f"/>
<meta name="description" content="APK Patch Suite — Flutter SSL bypass, APK patcher, Smali patch, Pairip bypass. Langsung di browser."/>
<title>APK Patch Suite — Flutter SSL + ApkPatcher</title>
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🛡️</text></svg>"/>
<style>
/* ══ RESET & DESIGN TOKENS ══════════════════════════════════════════════ */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#07090f;--surf:#0c0f1a;--card:#101525;--card2:#0b1020;
  --b1:#1a2540;--b2:#223058;--b3:#2d4070;
  --p:#6366f1;--p2:#818cf8;--p3:#4f46e5;--p4:rgba(99,102,241,.12);
  --green:#10b981;--g2:#34d399;
  --red:#ef4444;--r2:#fca5a5;
  --yel:#f59e0b;--y2:#fcd34d;
  --blue:#3b82f6;--b2c:#93c5fd;
  --cyan:#06b6d4;--c2:#67e8f9;
  --org:#f97316;--o2:#fdba74;
  --txt:#e2e8f0;--mu:#64748b;--mu2:#94a3b8;
  --r:12px;--rs:8px;--rxs:6px;
  --shadow:0 4px 24px rgba(0,0,0,.4);
  --glow-p:0 0 40px rgba(99,102,241,.15);
  --t:.22s cubic-bezier(.4,0,.2,1);
  --safe-top:env(safe-area-inset-top,0px);
  --safe-bot:env(safe-area-inset-bottom,0px);
  --safe-l:env(safe-area-inset-left,0px);
  --safe-r:env(safe-area-inset-right,0px);
}

html{scroll-behavior:smooth;-webkit-text-size-adjust:100%;height:100%}
body{
  background:var(--bg);color:var(--txt);
  font-family:'Segoe UI',system-ui,-apple-system,'Helvetica Neue',sans-serif;
  min-height:100%;line-height:1.6;overflow-x:hidden;
}

/* ── Scrollbar ── */
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--p);border-radius:99px}
::-webkit-scrollbar-thumb:hover{background:var(--p2)}

/* ══ NAVBAR ══════════════════════════════════════════════════════════════ */
.nav{
  position:sticky;top:0;z-index:300;
  background:rgba(7,9,15,.92);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);
  border-bottom:1px solid var(--b1);
  padding-left:max(1rem,var(--safe-l));padding-right:max(1rem,var(--safe-r));
}
.nav-inner{
  max-width:1200px;margin:0 auto;
  height:56px;display:flex;align-items:center;justify-content:space-between;gap:.5rem;
}
.nav-brand{
  display:flex;align-items:center;gap:.5rem;
  font-weight:900;font-size:.95rem;color:#fff;text-decoration:none;
  white-space:nowrap;flex-shrink:0;min-width:0;
}
.nav-brand .logo{font-size:1.3rem;line-height:1;flex-shrink:0}
.nav-brand .brand-text{overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.nav-links{display:flex;gap:.1rem;flex-shrink:0}
.nav-links a{
  font-size:.78rem;font-weight:500;color:var(--mu2);
  padding:.35rem .65rem;border-radius:6px;text-decoration:none;transition:var(--t);
  white-space:nowrap;
}
.nav-links a:hover{background:rgba(255,255,255,.07);color:#fff}
.nav-gh{
  display:flex;align-items:center;gap:.4rem;flex-shrink:0;
  background:rgba(255,255,255,.05);border:1px solid var(--b2);
  color:var(--mu2);font-size:.75rem;font-weight:600;
  padding:.35rem .8rem;border-radius:7px;text-decoration:none;transition:var(--t);
}
.nav-gh:hover{background:rgba(255,255,255,.1);color:#fff;border-color:var(--b3)}
.nav-gh svg{width:13px;height:13px;fill:currentColor;flex-shrink:0}
@media(max-width:700px){.nav-links{display:none}}
@media(max-width:420px){.nav-gh .nav-gh-text{display:none}}

/* ══ HERO ════════════════════════════════════════════════════════════════ */
.hero{
  position:relative;overflow:hidden;
  padding:clamp(2.25rem,7vw,4.5rem) clamp(1rem,4vw,1.5rem) clamp(1.75rem,5vw,3rem);
  text-align:center;
}
.hero::before{
  content:'';position:absolute;inset:0;pointer-events:none;
  background:
    radial-gradient(ellipse 90% 55% at 50% -5%,rgba(99,102,241,.18) 0%,transparent 70%),
    radial-gradient(ellipse 55% 35% at 80% 95%,rgba(16,185,129,.08) 0%,transparent 60%),
    radial-gradient(ellipse 40% 30% at 10% 80%,rgba(59,130,246,.06) 0%,transparent 55%);
}
.hero-badge{
  display:inline-flex;align-items:center;gap:.42rem;
  background:rgba(99,102,241,.12);border:1px solid rgba(99,102,241,.3);
  color:var(--p2);font-size:.7rem;font-weight:700;letter-spacing:.07em;
  padding:.3rem .95rem;border-radius:99px;margin-bottom:1.1rem;text-transform:uppercase;
}
.hero h1{
  font-size:clamp(1.7rem,5.5vw,3rem);font-weight:900;
  line-height:1.1;color:#fff;margin-bottom:.8rem;
}
.grad{
  background:linear-gradient(135deg,#818cf8 0%,#6366f1 45%,#34d399 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.hero-sub{
  max-width:560px;margin:0 auto 1.5rem;
  color:var(--mu2);font-size:clamp(.85rem,2.5vw,1rem);
}
.chips{display:flex;flex-wrap:wrap;justify-content:center;gap:.4rem;margin-bottom:2rem}
.chip{
  display:inline-flex;align-items:center;gap:.32rem;
  font-size:.7rem;font-weight:700;padding:.26rem .75rem;border-radius:99px;white-space:nowrap;
}
.ch-c{background:rgba(6,182,212,.1);color:var(--c2);border:1px solid rgba(6,182,212,.22)}
.ch-o{background:rgba(249,115,22,.1);color:var(--o2);border:1px solid rgba(249,115,22,.22)}
.ch-g{background:rgba(16,185,129,.1);color:var(--g2);border:1px solid rgba(16,185,129,.22)}
.ch-p{background:rgba(99,102,241,.1);color:var(--p2);border:1px solid rgba(99,102,241,.22)}
.ch-b{background:rgba(59,130,246,.1);color:var(--b2c);border:1px solid rgba(59,130,246,.22)}
.ch-y{background:rgba(245,158,11,.1);color:var(--y2);border:1px solid rgba(245,158,11,.22)}

/* ══ LAYOUT ══════════════════════════════════════════════════════════════ */
.main{max-width:1200px;margin:0 auto;padding:0 clamp(.75rem,3vw,1.5rem) 5rem}
.section{margin-bottom:2.5rem}
.section-title{
  display:flex;align-items:center;gap:.5rem;
  font-size:1.05rem;font-weight:800;color:#fff;margin-bottom:1rem;
}

/* ══ MODE SWITCHER ════════════════════════════════════════════════════════ */
.mode-tabs{
  display:grid;grid-template-columns:1fr 1fr;gap:.4rem;
  background:var(--card2);border:1px solid var(--b1);
  border-radius:13px;padding:.38rem;margin-bottom:1.75rem;
}
.mode-tab{
  display:flex;align-items:center;justify-content:center;gap:.5rem;
  padding:.75rem 1rem;border-radius:9px;cursor:pointer;
  font-size:.86rem;font-weight:700;transition:var(--t);
  border:1px solid transparent;background:transparent;color:var(--mu2);
  -webkit-tap-highlight-color:transparent;font-family:inherit;
  position:relative;
}
.mode-tab:hover{color:#fff;background:rgba(255,255,255,.05)}
.mode-tab.active{
  background:linear-gradient(135deg,rgba(99,102,241,.24),rgba(99,102,241,.11));
  color:#fff;border-color:rgba(99,102,241,.35);
  box-shadow:0 4px 20px rgba(99,102,241,.16);
}
.mode-tab .ti{font-size:1.1rem;flex-shrink:0}
.mode-tab .tl{font-size:.83rem;font-weight:700;line-height:1.2}
.mode-tab .ts{font-size:.66rem;color:var(--mu);font-weight:500;line-height:1}
.mode-tab.active .ts{color:var(--mu2)}
.mode-tab .tb{
  font-size:.6rem;background:rgba(99,102,241,.18);color:var(--p2);
  padding:.09rem .45rem;border-radius:99px;border:1px solid rgba(99,102,241,.28);
  margin-left:auto;white-space:nowrap;flex-shrink:0;
}
@media(max-width:400px){
  .mode-tab{flex-direction:column;gap:.28rem;padding:.65rem .4rem;font-size:.78rem}
  .mode-tab .tb{margin-left:0}
  .mode-tab .ts{display:none}
}

.mode-content{display:none}
.mode-content.active{display:block;animation:fadeUp .3s ease}

/* ══ TOOL CARD ════════════════════════════════════════════════════════════ */
.tool-card{
  background:linear-gradient(148deg,var(--card),var(--card2));
  border:1px solid var(--b1);border-radius:16px;overflow:hidden;
  box-shadow:var(--shadow);transition:border-color var(--t);
}
.tool-card:hover{border-color:var(--b2)}

.stats-bar{
  display:flex;flex-wrap:wrap;gap:.6rem .85rem;
  padding:.7rem 1.2rem;border-bottom:1px solid var(--b1);
  background:rgba(99,102,241,.04);
}
.si{display:flex;align-items:center;gap:.38rem;font-size:.76rem}
.sd{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.sl{color:var(--mu)}
.sv{font-weight:700;color:#fff}

.tool-header{
  padding:1.1rem 1.4rem;border-bottom:1px solid var(--b1);
  display:flex;align-items:flex-start;gap:.8rem;
  background:rgba(99,102,241,.03);
}
.th-icon{font-size:1.55rem;line-height:1;flex-shrink:0;margin-top:.05rem}
.th-title{font-size:.97rem;font-weight:800;color:#fff;margin-bottom:.12rem}
.th-sub{font-size:.76rem;color:var(--mu);line-height:1.45}

.tool-body{padding:clamp(.9rem,3vw,1.6rem)}

/* ══ DROPZONE ════════════════════════════════════════════════════════════ */
.dropzone{
  border:2px dashed var(--b2);border-radius:var(--r);
  padding:clamp(1.6rem,5vw,2.75rem) clamp(.9rem,4vw,2rem);
  text-align:center;cursor:pointer;transition:var(--t);
  position:relative;background:rgba(99,102,241,.02);
  -webkit-tap-highlight-color:transparent;user-select:none;-webkit-user-select:none;
}
.dropzone:hover,.dropzone.over{border-color:var(--p);background:rgba(99,102,241,.07)}
.dropzone.over{box-shadow:inset 0 0 0 2px rgba(99,102,241,.25)}
.dropzone.has-file{border-style:solid;border-color:rgba(16,185,129,.4);background:rgba(16,185,129,.03)}
.dropzone input[type=file]{
  position:absolute;inset:0;opacity:0;cursor:pointer;
  width:100%;height:100%;font-size:0;
}
.dz-icon{
  width:50px;height:50px;margin:0 auto .8rem;
  background:rgba(99,102,241,.12);border:1px solid rgba(99,102,241,.25);
  border-radius:12px;display:flex;align-items:center;justify-content:center;
  font-size:1.4rem;transition:var(--t);
}
.dropzone:hover .dz-icon,.dropzone.over .dz-icon{
  transform:scale(1.08) translateY(-2px);background:rgba(99,102,241,.22);
}
.dz-title{font-weight:700;color:#fff;font-size:.92rem;margin-bottom:.28rem}
.dz-title code{
  background:rgba(99,102,241,.15);padding:.05rem .38rem;
  border-radius:4px;color:var(--p2);font-size:.88em;
}
.dz-sub{color:var(--mu);font-size:.8rem}
.dz-hint{
  display:inline-flex;align-items:center;gap:.35rem;margin-top:.7rem;
  font-size:.7rem;color:var(--mu);background:rgba(255,255,255,.03);
  border:1px solid var(--b1);padding:.26rem .68rem;border-radius:99px;
}
@media(hover:none){.dz-hint .drag-only{display:none}}

/* ══ FILE PREVIEW ═════════════════════════════════════════════════════════ */
.file-preview{
  display:none;align-items:center;gap:.8rem;
  background:rgba(16,185,129,.05);border:1px solid rgba(16,185,129,.18);
  border-radius:var(--rs);padding:.78rem .95rem;margin-top:.8rem;
  animation:fadeUp .25s ease;
}
.file-preview.show{display:flex}
.fp-icon{
  width:34px;height:34px;min-width:34px;
  background:rgba(16,185,129,.14);border-radius:8px;
  display:flex;align-items:center;justify-content:center;font-size:.95rem;
  flex-shrink:0;
}
.fp-info{flex:1;min-width:0}
.fp-name{font-weight:700;color:#fff;font-size:.83rem;word-break:break-all;line-height:1.3}
.fp-meta{font-size:.72rem;color:var(--mu2);margin-top:.08rem}
.fp-rm{
  margin-left:auto;flex-shrink:0;cursor:pointer;
  width:24px;height:24px;background:rgba(239,68,68,.1);
  border:1px solid rgba(239,68,68,.2);border-radius:6px;
  display:flex;align-items:center;justify-content:center;
  font-size:.75rem;color:var(--r2);transition:var(--t);
  -webkit-tap-highlight-color:transparent;
}
.fp-rm:hover{background:rgba(239,68,68,.28)}

/* ══ UPLOAD PROGRESS ══════════════════════════════════════════════════════ */
.up-prog{display:none;margin-top:.65rem}
.up-prog.show{display:block;animation:fadeUp .2s ease}
.up-prog-label{font-size:.72rem;color:var(--mu2);display:flex;justify-content:space-between;margin-bottom:.28rem}
.up-prog-bar{height:4px;border-radius:99px;background:var(--b1);overflow:hidden}
.up-prog-fill{height:100%;background:linear-gradient(90deg,var(--p3),var(--p2));border-radius:99px;transition:width .12s linear;width:0}

/* ══ OPTIONS ══════════════════════════════════════════════════════════════ */
.opt-row{
  display:grid;grid-template-columns:1fr 1fr;gap:.8rem;
  margin-top:1.1rem;
}
@media(max-width:520px){.opt-row{grid-template-columns:1fr}}

.opt-group label.opt-label{
  display:block;font-size:.72rem;font-weight:700;
  color:var(--mu2);letter-spacing:.05em;text-transform:uppercase;margin-bottom:.38rem;
}
.sel-wrap{position:relative}
.sel-wrap select{
  width:100%;background:var(--card2);border:1px solid var(--b2);border-radius:var(--rs);
  color:var(--txt);font-size:.84rem;padding:.55rem .9rem;padding-right:2.1rem;
  outline:none;transition:var(--t);cursor:pointer;appearance:none;-webkit-appearance:none;
}
.sel-wrap select:focus{border-color:var(--p);box-shadow:0 0 0 2px rgba(99,102,241,.18)}
.sel-wrap::after{
  content:'▾';position:absolute;right:.75rem;top:50%;transform:translateY(-50%);
  color:var(--mu);pointer-events:none;font-size:.76rem;
}

/* Toggle switch */
.tg-row{display:flex;align-items:center;gap:.6rem;margin-top:.32rem}
.tg{
  position:relative;display:inline-flex;align-items:center;
  width:38px;height:21px;cursor:pointer;flex-shrink:0;
}
.tg input{opacity:0;width:0;height:0;position:absolute}
.tg-track{width:38px;height:21px;background:var(--b2);border-radius:99px;transition:var(--t)}
.tg input:checked+.tg-track{background:var(--p)}
.tg-thumb{
  position:absolute;left:3px;top:2.5px;width:16px;height:16px;
  border-radius:99px;background:#fff;transition:var(--t);
  box-shadow:0 1px 4px rgba(0,0,0,.3);
}
.tg input:checked~.tg-thumb{transform:translateX(17px)}
.tg-label{font-size:.82rem;color:var(--mu2);cursor:pointer;line-height:1.35;user-select:none}

/* Patch option cards */
.patch-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(min(100%,250px),1fr));
  gap:.55rem;margin-top:.7rem;
}
@media(max-width:420px){.patch-grid{grid-template-columns:1fr}}

.popt{
  display:flex;align-items:flex-start;gap:.58rem;
  padding:.7rem .85rem;background:rgba(255,255,255,.025);
  border:1px solid var(--b1);border-radius:var(--rs);
  cursor:pointer;transition:var(--t);-webkit-tap-highlight-color:transparent;
  user-select:none;-webkit-user-select:none;
}
.popt:hover{border-color:var(--b2);background:rgba(255,255,255,.04)}
.popt.on{background:rgba(99,102,241,.08);border-color:rgba(99,102,241,.32)}
.popt input[type=checkbox]{
  margin-top:.16rem;width:15px;height:15px;min-width:15px;
  accent-color:var(--p);cursor:pointer;flex-shrink:0;
}
.popt-body{flex:1;min-width:0}
.popt-name{
  font-size:.8rem;font-weight:700;color:#fff;
  display:flex;align-items:center;justify-content:space-between;gap:.38rem;flex-wrap:wrap;
}
.pf{
  font-family:'Cascadia Code','Fira Code','Consolas',monospace;
  font-size:.63rem;background:rgba(99,102,241,.14);
  color:var(--p2);padding:.07rem .38rem;border-radius:4px;flex-shrink:0;white-space:nowrap;
}
.popt-desc{font-size:.68rem;color:var(--mu);margin-top:.08rem;line-height:1.4}

/* ══ INPUT ════════════════════════════════════════════════════════════════ */
.inp{
  width:100%;background:var(--card2);border:1px solid var(--b2);
  border-radius:var(--rs);color:var(--txt);font-size:.84rem;
  padding:.55rem .88rem;outline:none;transition:var(--t);font-family:inherit;
}
.inp:focus{border-color:var(--p);box-shadow:0 0 0 2px rgba(99,102,241,.18)}
.inp::placeholder{color:var(--mu)}
.inp-hint{font-size:.68rem;color:var(--mu);margin-top:.32rem}

/* ══ BUTTONS ══════════════════════════════════════════════════════════════ */
.btn{
  display:inline-flex;align-items:center;justify-content:center;gap:.48rem;
  border:none;border-radius:var(--rs);font-weight:800;cursor:pointer;
  transition:var(--t);position:relative;overflow:hidden;
  text-decoration:none;-webkit-tap-highlight-color:transparent;font-family:inherit;
}
.btn:disabled{opacity:.4;cursor:not-allowed;pointer-events:none}

.btn-primary{
  background:linear-gradient(135deg,var(--p3),var(--p));color:#fff;
  font-size:.92rem;padding:.84rem 1.4rem;width:100%;margin-top:1rem;
  box-shadow:0 4px 20px rgba(99,102,241,.22);
}
.btn-primary::after{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(255,255,255,.12),transparent);
  opacity:0;transition:var(--t);
}
.btn-primary:hover:not(:disabled)::after{opacity:1}
.btn-primary:hover:not(:disabled){transform:translateY(-1px);box-shadow:0 8px 28px rgba(99,102,241,.32)}
.btn-primary:active:not(:disabled){transform:translateY(0);box-shadow:0 2px 12px rgba(99,102,241,.2)}

/* Loading spinner in button */
.spin{
  width:16px;height:16px;
  border:2.5px solid rgba(255,255,255,.28);border-top-color:#fff;
  border-radius:50%;animation:spin .65s linear infinite;display:none;flex-shrink:0;
}
.btn-primary.loading .spin{display:block}
.btn-primary.loading .btn-text{display:none}

/* Download button */
.btn-dl{
  display:inline-flex;align-items:center;gap:.48rem;
  background:linear-gradient(135deg,#065f46,var(--green));
  border:none;border-radius:var(--rs);color:#fff;font-size:.88rem;font-weight:800;
  padding:.74rem 1.4rem;cursor:pointer;transition:var(--t);text-decoration:none;
  font-family:inherit;box-shadow:0 4px 18px rgba(16,185,129,.22);
}
.btn-dl:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(16,185,129,.32)}
.btn-dl:active{transform:translateY(0)}
.btn-dl svg{width:15px;height:15px;fill:currentColor;flex-shrink:0}

/* Secondary button */
.btn-sec{
  display:inline-flex;align-items:center;gap:.42rem;
  background:rgba(255,255,255,.05);border:1px solid var(--b2);
  color:var(--mu2);font-size:.8rem;font-weight:600;
  padding:.56rem 1.05rem;border-radius:var(--rs);
  cursor:pointer;transition:var(--t);font-family:inherit;
  -webkit-tap-highlight-color:transparent;
}
.btn-sec:hover{background:rgba(255,255,255,.09);color:#fff;border-color:var(--b3)}

/* ══ PROGRESS BAR ═════════════════════════════════════════════════════════ */
.prog-wrap{display:none;margin-top:.9rem}
.prog-wrap.show{display:block;animation:fadeUp .25s ease}
.prog-top{
  display:flex;align-items:center;justify-content:space-between;
  font-size:.74rem;color:var(--mu2);margin-bottom:.35rem;
}
.prog-label{font-weight:600}
.prog-bg{background:var(--b1);border-radius:99px;height:6px;overflow:hidden}
.prog-fill{
  height:100%;border-radius:99px;width:0%;
  background:linear-gradient(90deg,var(--p3),var(--p2),var(--g2));
  background-size:200%;transition:width .45s ease;
  animation:shimmer 1.8s linear infinite;
}
.prog-fill.done{animation:none;background:var(--g2);width:100%!important}
.prog-fill.error{animation:none;background:var(--red);width:100%!important}
@keyframes shimmer{0%{background-position:0% 50%}100%{background-position:200% 50%}}

/* ══ LIVE LOG PANEL ═══════════════════════════════════════════════════════ */
.log-panel{display:none;margin-top:.9rem}
.log-panel.show{display:block;animation:fadeUp .25s ease}
.log-head{
  display:flex;align-items:center;justify-content:space-between;
  padding:.55rem .9rem;background:rgba(255,255,255,.03);
  border:1px solid var(--b1);border-radius:var(--rs) var(--rs) 0 0;
  border-bottom:none;
}
.log-title-txt{font-size:.76rem;font-weight:700;color:var(--mu2);display:flex;align-items:center;gap:.38rem}
.log-live-dot{
  width:6px;height:6px;border-radius:50%;background:var(--green);
  animation:pulse-dot 1.2s ease-in-out infinite;flex-shrink:0;
}
.log-live-dot.stopped{animation:none;background:var(--mu)}
.log-actions{display:flex;align-items:center;gap:.42rem}
.log-count{
  font-size:.66rem;background:rgba(99,102,241,.15);color:var(--p2);
  padding:.09rem .42rem;border-radius:99px;font-weight:700;
}
.log-btn{
  font-size:.68rem;color:var(--mu);cursor:pointer;background:none;border:none;
  padding:.16rem .42rem;border-radius:4px;transition:var(--t);font-family:inherit;
  -webkit-tap-highlight-color:transparent;
}
.log-btn:hover{color:var(--txt);background:rgba(255,255,255,.06)}

.log-body{
  background:#040710;border:1px solid var(--b1);
  border-radius:0 0 var(--rs) var(--rs);
  padding:.78rem .88rem;
  font-family:'Cascadia Code','Fira Code','Consolas',monospace;
  font-size:.73rem;line-height:1.85;
  max-height:min(320px,48vh);
  min-height:80px;
  overflow-y:auto;overflow-x:hidden;
  overscroll-behavior:contain;
  scroll-behavior:smooth;
}
/* Log line styles */
.log-line{display:flex;gap:.55rem;align-items:baseline;word-break:break-word;padding:.05rem 0}
.log-line+.log-line{border-top:1px solid rgba(255,255,255,.025)}
.log-ts{color:var(--mu);flex-shrink:0;font-size:.66rem;opacity:.65;min-width:60px;font-family:monospace}
.log-ico{flex-shrink:0;font-size:.72rem;min-width:16px;text-align:center}
.log-txt{flex:1;word-break:break-word}
.log-line.lv-info    .log-txt{color:#94a3b8}
.log-line.lv-step    .log-txt{color:#93c5fd;font-weight:600}
.log-line.lv-found   .log-txt{color:var(--y2);font-weight:700}
.log-line.lv-success .log-txt{color:var(--g2);font-weight:700}
.log-line.lv-error   .log-txt{color:var(--r2);font-weight:700}
.log-line.lv-warn    .log-txt{color:var(--y2)}

/* New log entry animation */
.log-line.new{animation:logSlide .2s ease}
@keyframes logSlide{from{opacity:0;transform:translateX(-4px)}to{opacity:1;transform:translateX(0)}}

/* ══ RESULT PANEL ═════════════════════════════════════════════════════════ */
.result-panel{display:none;margin-top:.9rem}
.result-panel.show{display:block;animation:fadeUp .3s ease}

.res-ok{
  background:rgba(16,185,129,.06);border:1px solid rgba(16,185,129,.26);
  border-radius:var(--r);padding:1.2rem;
}
.res-err{
  background:rgba(239,68,68,.06);border:1px solid rgba(239,68,68,.26);
  border-radius:var(--r);padding:1.2rem;
}
.res-head{display:flex;align-items:flex-start;gap:.65rem;margin-bottom:.9rem}
.res-ico{
  width:38px;height:38px;min-width:38px;border-radius:10px;
  display:flex;align-items:center;justify-content:center;font-size:1.15rem;flex-shrink:0;
}
.res-ico-ok{background:rgba(16,185,129,.15)}
.res-ico-err{background:rgba(239,68,68,.15)}
.res-t{font-size:.92rem;font-weight:800;color:#fff;margin-bottom:.12rem}
.res-s{font-size:.76rem;color:var(--mu2);line-height:1.45}

.meta-grid{
  display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));
  gap:.5rem;margin-bottom:.9rem;
}
.mi{background:rgba(0,0,0,.22);border:1px solid rgba(255,255,255,.06);border-radius:7px;padding:.55rem .8rem}
.mi-l{font-size:.63rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:var(--mu);margin-bottom:.2rem}
.mi-v{font-size:.8rem;font-weight:700;color:#fff;font-family:monospace;word-break:break-all}

.res-actions{display:flex;align-items:center;flex-wrap:wrap;gap:.6rem;margin-top:.8rem}
@media(max-width:480px){
  .res-actions{flex-direction:column;align-items:stretch}
  .res-actions .btn-dl,.res-actions .btn-sec{width:100%;justify-content:center}
}

/* ══ SCAN RESULT ══════════════════════════════════════════════════════════ */
.scan-res{
  display:none;margin-top:.8rem;
  padding:.85rem 1.05rem;border-radius:var(--rs);
  background:rgba(59,130,246,.06);border:1px solid rgba(59,130,246,.2);
  animation:fadeUp .25s ease;
}
.scan-res.show{display:block}
.scan-title{font-size:.78rem;font-weight:700;color:#fff;margin-bottom:.45rem}
.scan-chips{display:flex;flex-wrap:wrap;gap:.38rem}

/* ══ STEP FLOW ════════════════════════════════════════════════════════════ */
.step-flow{display:flex;flex-direction:column;gap:1rem}
.step-item{
  display:flex;gap:.85rem;align-items:flex-start;
  transition:opacity var(--t);
}
.step-num{
  width:26px;height:26px;min-width:26px;border-radius:50%;
  background:rgba(99,102,241,.16);border:1px solid rgba(99,102,241,.35);
  display:flex;align-items:center;justify-content:center;
  font-size:.72rem;font-weight:800;color:var(--p2);margin-top:.06rem;
  transition:var(--t);flex-shrink:0;
}
.step-num.done-num{background:rgba(16,185,129,.18);border-color:rgba(16,185,129,.4);color:var(--g2)}
.step-body{flex:1;min-width:0}
.step-title{font-size:.86rem;font-weight:700;color:#fff;margin-bottom:.38rem}
.step-sub{font-size:.74rem;color:var(--mu);margin-bottom:.65rem;line-height:1.5}
.step-content{display:none}
.step-content.open{display:block;animation:fadeUp .28s ease}

/* ══ JOB STATUS ═══════════════════════════════════════════════════════════ */
.job-status-row{
  display:flex;align-items:center;gap:.6rem;flex-wrap:wrap;
  margin-top:.62rem;font-size:.72rem;
}
.status-pill{
  display:inline-flex;align-items:center;gap:.35rem;
  font-size:.72rem;font-weight:700;padding:.24rem .72rem;border-radius:99px;
}
.sp-ok{background:rgba(16,185,129,.12);color:var(--g2);border:1px solid rgba(16,185,129,.26)}
.sp-err{background:rgba(239,68,68,.12);color:var(--r2);border:1px solid rgba(239,68,68,.26)}
.sp-run{background:rgba(99,102,241,.12);color:var(--p2);border:1px solid rgba(99,102,241,.26)}
.sp-pulse::before{
  content:'';display:inline-block;width:5px;height:5px;border-radius:50%;
  background:currentColor;animation:pulse-dot 1.1s ease-in-out infinite;
}
.elapsed{color:var(--mu);font-size:.7rem}

/* ══ ALERTS ══════════════════════════════════════════════════════════════ */
.alert{
  border-radius:var(--rs);padding:.72rem .9rem;
  display:flex;gap:.6rem;font-size:.78rem;line-height:1.55;align-items:flex-start;
}
.alert-w{background:rgba(245,158,11,.07);border:1px solid rgba(245,158,11,.24);color:var(--y2)}
.alert-i{background:rgba(59,130,246,.07);border:1px solid rgba(59,130,246,.24);color:var(--b2c)}
.alert-s{background:rgba(16,185,129,.07);border:1px solid rgba(16,185,129,.24);color:var(--g2)}
.alert-e{background:rgba(239,68,68,.07);border:1px solid rgba(239,68,68,.24);color:var(--r2)}
.alert-ico{flex-shrink:0;margin-top:.06rem}

/* ══ GRIDS ════════════════════════════════════════════════════════════════ */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
.g3{display:grid;grid-template-columns:repeat(3,1fr);gap:.8rem}
@media(max-width:640px){.g2,.g3{grid-template-columns:1fr}}
@media(min-width:641px) and (max-width:880px){.g3{grid-template-columns:1fr 1fr}}

/* ══ INFO CARDS ══════════════════════════════════════════════════════════ */
.ic{padding:1.05rem;border-radius:var(--r)}
.ic .ici{font-size:1.3rem;margin-bottom:.45rem}
.ic h3{font-size:.86rem;font-weight:800;color:#fff;margin-bottom:.28rem}
.ic p{font-size:.76rem;color:var(--mu2);line-height:1.55}

/* Flow diagram */
.flow-row{
  display:flex;align-items:center;justify-content:center;
  flex-wrap:wrap;gap:.4rem;padding:1.1rem .9rem;
}
.fn{
  background:var(--card2);border:1px solid var(--b1);
  border-radius:9px;padding:.58rem .85rem;text-align:center;min-width:85px;
}
.fn-ico{font-size:1.15rem;margin-bottom:.2rem}
.fn-t{font-size:.73rem;font-weight:700;color:#fff}
.fn-s{font-size:.63rem;color:var(--mu);margin-top:.05rem}
.arr{color:var(--p2);font-size:1rem;flex-shrink:0}
@media(max-width:480px){
  .flow-row{gap:.28rem}
  .fn{min-width:68px;padding:.46rem .55rem}
  .fn-t{font-size:.66rem}
  .arr{font-size:.85rem}
}

/* ══ TABS ════════════════════════════════════════════════════════════════ */
.tabs{
  display:flex;gap:.18rem;padding:.6rem .9rem .38rem;
  border-bottom:1px solid var(--b1);overflow-x:auto;
  -webkit-overflow-scrolling:touch;scrollbar-width:none;
}
.tabs::-webkit-scrollbar{height:0}
.tab-btn{
  font-size:.76rem;font-weight:700;padding:.35rem .75rem;border-radius:5px;
  cursor:pointer;border:none;background:transparent;color:var(--mu2);
  transition:var(--t);white-space:nowrap;font-family:inherit;
  -webkit-tap-highlight-color:transparent;
}
.tab-btn:hover{background:rgba(255,255,255,.05);color:#fff}
.tab-btn.active{background:rgba(99,102,241,.14);color:var(--p2)}
.tab-pane{display:none;padding:1.05rem}
.tab-pane.active{display:block;animation:fadeUp .22s ease}

/* Pattern items */
.pat-item{
  background:#030810;border:1px solid var(--b1);border-radius:5px;
  padding:.5rem .78rem;font-family:monospace;font-size:.68rem;
  color:#7dd3fc;word-break:break-all;margin-bottom:.38rem;line-height:1.55;
  transition:border-color var(--t);
}
.pat-item:hover{border-color:var(--p)}
.pat-n{color:var(--mu);margin-right:.48rem}

/* Code blocks */
.code-blk{background:#030810;border:1px solid var(--b1);border-radius:var(--rs);overflow:hidden}
.code-hd{
  background:rgba(255,255,255,.03);padding:.4rem .9rem;
  display:flex;align-items:center;justify-content:space-between;
  border-bottom:1px solid var(--b1);font-size:.7rem;color:var(--mu);
}
.code-blk pre{padding:.8rem .9rem;overflow-x:auto;font-size:.74rem;line-height:1.7;margin:0}
.code-blk code{font-family:'Cascadia Code','Fira Code','Consolas',monospace;color:#e2e8f0}
.cp-btn{
  background:rgba(99,102,241,.12);border:1px solid rgba(99,102,241,.24);
  color:var(--p2);font-size:.66rem;font-weight:600;
  padding:.13rem .48rem;border-radius:4px;cursor:pointer;
  transition:var(--t);font-family:inherit;-webkit-tap-highlight-color:transparent;
}
.cp-btn:hover{background:rgba(99,102,241,.26);color:#fff}
.cp-btn.ok{background:rgba(16,185,129,.12);border-color:rgba(16,185,129,.3);color:var(--g2)}

/* ══ TABLE ════════════════════════════════════════════════════════════════ */
.feat-table{width:100%;border-collapse:collapse;font-size:.8rem}
.feat-table th,.feat-table td{padding:.54rem .72rem;text-align:left;border-bottom:1px solid var(--b1)}
.feat-table th{color:var(--p2);font-weight:700;background:rgba(99,102,241,.07)}
.feat-table td{color:var(--mu2)}
.feat-table td:first-child{color:#fff;font-weight:600}
.feat-table tr:last-child td{border-bottom:none}
.feat-table tr:hover td{background:rgba(99,102,241,.04)}
.tick{color:var(--g2)}

/* ══ TOAST ════════════════════════════════════════════════════════════════ */
#toast{
  position:fixed;
  bottom:max(1.4rem,var(--safe-bot));
  left:50%;transform:translateX(-50%) translateY(6px);
  background:rgba(18,26,46,.97);border:1px solid var(--b2);
  color:#fff;font-size:.82rem;font-weight:600;
  padding:.62rem 1.2rem;border-radius:99px;
  box-shadow:0 8px 32px rgba(0,0,0,.5);
  opacity:0;transition:opacity .2s,transform .2s;
  pointer-events:none;white-space:nowrap;z-index:9999;
  backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);
  max-width:calc(100vw - 2rem);text-overflow:ellipsis;overflow:hidden;
}
#toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

/* ══ CONNECTION INDICATOR ═════════════════════════════════════════════════ */
#conn-status{
  position:fixed;top:64px;right:max(1rem,var(--safe-r));z-index:200;
  font-size:.68rem;font-weight:700;padding:.2rem .62rem;border-radius:99px;
  display:none;backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);
  transition:var(--t);
}
#conn-status.offline{
  display:flex;align-items:center;gap:.3rem;
  background:rgba(239,68,68,.15);border:1px solid rgba(239,68,68,.3);color:var(--r2);
}
#conn-status.reconnecting{
  display:flex;align-items:center;gap:.3rem;
  background:rgba(245,158,11,.12);border:1px solid rgba(245,158,11,.3);color:var(--y2);
}

/* ══ FOOTER ══════════════════════════════════════════════════════════════ */
footer{
  border-top:1px solid var(--b1);
  padding:1.6rem 1rem max(1.6rem,var(--safe-bot));
  text-align:center;color:var(--mu);font-size:.76rem;
}
footer a{color:var(--p2);text-decoration:none}
footer a:hover{text-decoration:underline}
.fi{max-width:1200px;margin:0 auto}

/* ══ KEYFRAMES ════════════════════════════════════════════════════════════ */
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
@keyframes pulse-dot{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.35;transform:scale(.8)}}
.fade-up{animation:fadeUp .4s ease both}

/* ══ UTILITY ══════════════════════════════════════════════════════════════ */
.hidden{display:none!important}
.mt{margin-top:.8rem}
.sep{height:1px;background:var(--b1);margin:.9rem 0}

/* ══ MOBILE FINE-TUNING ═══════════════════════════════════════════════════ */
@media(max-width:480px){
  .hero{padding:2rem .85rem 1.6rem}
  .tool-header{padding:.9rem 1rem}
  .tool-body{padding:.88rem}
  .log-body{font-size:.7rem;max-height:200px;min-height:60px}
  .meta-grid{grid-template-columns:1fr 1fr}
  .btn-primary{font-size:.85rem;padding:.78rem 1.1rem}
  .stats-bar{padding:.6rem 1rem}
  .fn{min-width:62px}
}
@media(max-width:360px){
  .chips .chip:nth-child(n+5){display:none}
  .hero h1{font-size:1.55rem}
}
/* Touch devices: no hover states that persist */
@media(hover:none) and (pointer:coarse){
  .dropzone:hover{border-color:var(--b2);background:rgba(99,102,241,.02)}
  .dropzone:hover .dz-icon{transform:none;background:rgba(99,102,241,.12)}
  .tool-card:hover{border-color:var(--b1)}
}
</style>
</head>
<body>

<!-- Connection status indicator -->
<div id="conn-status" role="status" aria-live="polite"></div>
<!-- Toast notification -->
<div id="toast" role="status" aria-live="assertive"></div>

<!-- ═══ NAVBAR ═══ -->
<nav class="nav" role="navigation" aria-label="Main navigation">
  <div class="nav-inner">
    <a class="nav-brand" href="#" aria-label="APK Patch Suite home">
      <span class="logo" aria-hidden="true">🛡️</span>
      <span class="brand-text">APK Patch Suite</span>
    </a>
    <div class="nav-links" role="list">
      <a href="#tool" role="listitem">Tool</a>
      <a href="#how" role="listitem">Cara Kerja</a>
      <a href="#patterns" role="listitem">Patterns</a>
      <a href="#faq" role="listitem">FAQ</a>
    </div>
    <a class="nav-gh" href="https://github.com/TechnoIndian/ApkPatcher" target="_blank" rel="noopener noreferrer" aria-label="GitHub repository">
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 .3a12 12 0 0 0-3.8 23.38c.6.11.82-.26.82-.58l-.02-2.04c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.74.08-.73.08-.73 1.21.09 1.85 1.24 1.85 1.24 1.07 1.84 2.81 1.3 3.5 1 .1-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.14-.3-.54-1.52.1-3.18 0 0 1-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.28-1.55 3.29-1.23 3.29-1.23.65 1.66.24 2.88.12 3.18a4.65 4.65 0 0 1 1.23 3.22c0 4.61-2.8 5.63-5.48 5.92.43.37.81 1.1.81 2.22l-.01 3.29c0 .32.21.7.82.58A12 12 0 0 0 12 .3z"/></svg>
      <span class="nav-gh-text">GitHub</span>
    </a>
  </div>
</nav>

<!-- ═══ HERO ═══ -->
<header class="hero fade-up" id="home">
  <div class="hero-badge" aria-label="Android Security Research Tool">🔬 Android Security Research Tool</div>
  <h1>APK <span class="grad">Patch Suite</span></h1>
  <p class="hero-sub">Bypass SSL Flutter, patch Smali, bypass Pairip & lebih — langsung di browser, tanpa install apapun.</p>
  <div class="chips" aria-label="Features">
    <span class="chip ch-c">⚡ Flutter SSL</span>
    <span class="chip ch-o">📦 APK Patcher</span>
    <span class="chip ch-g">✅ No Install</span>
    <span class="chip ch-p">🧠 Auto Detect</span>
    <span class="chip ch-b">🔬 arm64/arm/x86</span>
    <span class="chip ch-y">🔓 Pairip Bypass</span>
  </div>
</header>

<!-- ═══ MAIN CONTENT ═══ -->
<main class="main" id="tool">

  <!-- Mode Switcher -->
  <div class="mode-tabs" role="tablist" aria-label="Tool mode selector">
    <button class="mode-tab active" id="tab-flutter" role="tab" aria-selected="true" aria-controls="mode-flutter"
            onclick="switchMode('flutter',this)">
      <span class="ti" aria-hidden="true">⚡</span>
      <div>
        <div class="tl">Flutter SSL Patch</div>
        <div class="ts">Patch libflutter.so binary</div>
      </div>
      <span class="tb" aria-hidden="true">libflutter.so</span>
    </button>
    <button class="mode-tab" id="tab-apk" role="tab" aria-selected="false" aria-controls="mode-apk"
            onclick="switchMode('apk',this)">
      <span class="ti" aria-hidden="true">📦</span>
      <div>
        <div class="tl">APK Patcher</div>
        <div class="ts">Patch full APK file</div>
      </div>
      <span class="tb" aria-hidden="true">ApkPatcher</span>
    </button>
  </div>

  <!-- ══════════════════════════════════════
       MODE A: FLUTTER SSL PATCH
  ══════════════════════════════════════ -->
  <div id="mode-flutter" class="mode-content active" role="tabpanel" aria-labelledby="tab-flutter">
    <section class="section">
      <div class="tool-card">
        <!-- Status bar -->
        <div class="stats-bar" aria-label="Tool status">
          <div class="si"><div class="sd" style="background:var(--g2)" aria-hidden="true"></div><span class="sl">Status</span><span class="sv" id="srv-status-f">Online</span></div>
          <div class="si"><div class="sd" style="background:var(--p2)" aria-hidden="true"></div><span class="sl">Engine</span><span class="sv">Pure Node.js</span></div>
          <div class="si"><div class="sd" style="background:var(--cyan)" aria-hidden="true"></div><span class="sl">Patterns</span><span class="sv">11 total</span></div>
          <div class="si"><div class="sd" style="background:var(--yel)" aria-hidden="true"></div><span class="sl">Max</span><span class="sv">150 MB</span></div>
        </div>

        <!-- Header -->
        <div class="tool-header">
          <span class="th-icon" aria-hidden="true">⚡</span>
          <div>
            <div class="th-title">Flutter SSL Certificate Bypass</div>
            <div class="th-sub">Upload <code>libflutter.so</code> → auto detect arch → patch <code>ssl_verify_peer_cert</code> → download patched binary</div>
          </div>
        </div>

        <div class="tool-body">
          <!-- Drop Zone -->
          <div class="dropzone" id="dz-f"
               ondragover="dzOver(this,event)" ondragleave="dzLeave(this)" ondrop="dzDrop(this,event,'f')"
               role="button" tabindex="0" aria-label="Upload libflutter.so — drop here or click to browse"
               onkeydown="if(event.key==='Enter'||event.key===' ')document.getElementById('file-f').click()">
            <input type="file" id="file-f" accept=".so,.bin" onchange="onPick(this,'f')"
                   tabindex="-1" aria-hidden="true"/>
            <div class="dz-icon" aria-hidden="true">📁</div>
            <div class="dz-title">Drop <code>libflutter.so</code> di sini</div>
            <div class="dz-sub">atau tap untuk pilih file</div>
            <div class="dz-hint"><span class="drag-only">Drag &amp; drop atau </span>📎 .so / .bin · maks 150 MB</div>
          </div>

          <!-- File preview -->
          <div class="file-preview" id="fp-f" role="status">
            <div class="fp-icon" aria-hidden="true">🔧</div>
            <div class="fp-info">
              <div class="fp-name" id="fp-f-name">—</div>
              <div class="fp-meta" id="fp-f-meta">—</div>
            </div>
            <button class="fp-rm" onclick="clearFile('f')" aria-label="Hapus file yang dipilih" title="Hapus">✕</button>
          </div>

          <!-- Upload progress -->
          <div id="up-prog-f" class="up-prog" role="status" aria-live="polite">
            <div class="up-prog-label">
              <span>Mengupload…</span>
              <span id="up-pct-f">0%</span>
            </div>
            <div class="up-prog-bar" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">
              <div class="up-prog-fill" id="up-fill-f"></div>
            </div>
          </div>

          <!-- Options -->
          <div class="opt-row">
            <div class="opt-group">
              <label class="opt-label" for="arch-f">Architecture</label>
              <div class="sel-wrap">
                <select id="arch-f" aria-label="Select architecture">
                  <option value="auto">🔍 Auto Detect (Rekomendasi)</option>
                  <option value="arm64">arm64 — 64-bit</option>
                  <option value="arm">arm — 32-bit</option>
                  <option value="x86">x86 / x86_64</option>
                </select>
              </div>
            </div>
            <div class="opt-group">
              <label class="opt-label" id="mode-f-label">Mode</label>
              <div class="tg-row" style="margin-top:.52rem">
                <label class="tg" title="Print Only — hanya tampilkan offset tanpa patch file">
                  <input type="checkbox" id="print-f" aria-labelledby="mode-f-label" aria-describedby="mode-f-desc"/>
                  <div class="tg-track"></div>
                  <div class="tg-thumb"></div>
                </label>
                <span class="tg-label" id="mode-f-desc" onclick="document.getElementById('print-f').click()">Print Only — lihat offset saja</span>
              </div>
            </div>
          </div>

          <!-- Action button -->
          <button class="btn btn-primary" id="btn-f" onclick="runFlutterPatch()" disabled
                  aria-label="Mulai patch Flutter SSL sekarang">
            <div class="spin" aria-hidden="true"></div>
            <span class="btn-text">⚡ Patch SSL Sekarang</span>
          </button>

          <!-- Progress bar -->
          <div class="prog-wrap" id="prog-f" role="status" aria-live="polite">
            <div class="prog-top">
              <span class="prog-label" id="prog-f-lbl">Memproses…</span>
              <span id="prog-f-pct" aria-hidden="true">—</span>
            </div>
            <div class="prog-bg">
              <div class="prog-fill" id="prog-f-fill" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
            </div>
          </div>

          <!-- Live log -->
          <div class="log-panel" id="log-f" role="log" aria-label="Log output Flutter patch" aria-live="polite">
            <div class="log-head">
              <span class="log-title-txt">
                <span class="log-live-dot" id="log-f-dot" aria-hidden="true"></span>
                📋 Live Log
                <span class="log-count" id="log-f-cnt" aria-label="log lines count">0</span>
              </span>
              <div class="log-actions">
                <button class="log-btn" onclick="scrollLog('f')" aria-label="Scroll ke bawah log">↓ Bawah</button>
                <button class="log-btn" onclick="clearLog('f')" aria-label="Hapus log">🗑 Clear</button>
              </div>
            </div>
            <div class="log-body" id="log-f-body"></div>
          </div>

          <!-- Result -->
          <div class="result-panel" id="result-f" role="status" aria-live="polite"></div>
        </div><!-- /tool-body -->
      </div><!-- /tool-card -->
    </section>

    <!-- How it works -->
    <section class="section" id="how">
      <div class="section-title">🔬 Cara Kerja Flutter SSL Patch</div>
      <div class="tool-card">
        <div class="flow-row" aria-label="Processing flow diagram">
          <div class="fn"><div class="fn-ico" aria-hidden="true">📁</div><div class="fn-t">Upload</div><div class="fn-s">libflutter.so</div></div>
          <div class="arr" aria-hidden="true">→</div>
          <div class="fn"><div class="fn-ico" aria-hidden="true">🔍</div><div class="fn-t">Detect ELF</div><div class="fn-s">arm64/arm/x86</div></div>
          <div class="arr" aria-hidden="true">→</div>
          <div class="fn"><div class="fn-ico" aria-hidden="true">🧩</div><div class="fn-t">Match Pattern</div><div class="fn-s">11 patterns</div></div>
          <div class="arr" aria-hidden="true">→</div>
          <div class="fn"><div class="fn-ico" aria-hidden="true">🎯</div><div class="fn-t">Find Fn Start</div><div class="fn-s">ssl_verify_peer_cert</div></div>
          <div class="arr" aria-hidden="true">→</div>
          <div class="fn"><div class="fn-ico" aria-hidden="true">✏️</div><div class="fn-t">Write ret0</div><div class="fn-s">Overwrite prologue</div></div>
          <div class="arr" aria-hidden="true">→</div>
          <div class="fn"><div class="fn-ico" aria-hidden="true">📥</div><div class="fn-t">Download</div><div class="fn-s">Patched .so</div></div>
        </div>
        <div style="padding:.8rem 1.2rem;border-top:1px solid var(--b1)">
          <div class="g2">
            <div class="alert alert-i"><span class="alert-ico" aria-hidden="true">ℹ️</span><div>Engine murni Node.js — tanpa radare2, tanpa dependency tambahan di sisi client.</div></div>
            <div class="alert alert-w"><span class="alert-ico" aria-hidden="true">⚠️</span><div>Hanya untuk security research &amp; CTF. Jangan gunakan melanggar ToS aplikasi.</div></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Byte Patterns -->
    <section class="section" id="patterns">
      <div class="section-title">🧩 Byte Patterns — ssl_verify_peer_cert</div>
      <div class="tool-card">
        <div class="tabs" role="tablist">
          <button class="tab-btn active" role="tab" onclick="switchTab(this,'pat-arm64')">arm64 (5)</button>
          <button class="tab-btn" role="tab" onclick="switchTab(this,'pat-arm')">arm (1)</button>
          <button class="tab-btn" role="tab" onclick="switchTab(this,'pat-x86')">x86 (5)</button>
          <button class="tab-btn" role="tab" onclick="switchTab(this,'pat-ret0')">ret0 Bytes</button>
        </div>
        <div id="pat-arm64" class="tab-pane active" role="tabpanel">
          <div class="pat-item"><span class="pat-n">[1]</span>F. 0F 1C F8 F. 5. 01 A9 F. 5. 02 A9 F. .. 03 A9 .. .. .. .. 68 1A 40 F9</div>
          <div class="pat-item"><span class="pat-n">[2]</span>F. 43 01 D1 FE 67 01 A9 F8 5F 02 A9 F6 57 03 A9 F4 4F 04 A9 13 00 40 F9 F4 03 00 AA 68 1A 40 F9</div>
          <div class="pat-item"><span class="pat-n">[3]</span>FF 43 01 D1 FE 67 01 A9 .. .. 06 94 .. 7. 06 94 68 1A 40 F9 15 15 41 F9 B5 00 00 B4 B6 4A 40 F9</div>
          <div class="pat-item"><span class="pat-n">[4]</span>FF .3 01 D1 F. .. 01 A9 .. .. .. 94 .. .. .. 52 48 00 00 39 1A 50 40 F9 DA 02 00 B4 48 03 40 F9</div>
          <div class="pat-item"><span class="pat-n">[5]</span>F. 0F 1C F8 F. .. 0. .. .. .. .. .9 .. .. 0. .. 68 1A 40 F9 15 .. 4. F9 B5 00 00 B4 B6 46 40 F9</div>
        </div>
        <div id="pat-arm" class="tab-pane" role="tabpanel">
          <div class="pat-item"><span class="pat-n">[1]</span>2D E9 F. 4. D0 F8 00 80 81 46 D8 F8 18 00 D0 F8</div>
        </div>
        <div id="pat-x86" class="tab-pane" role="tabpanel">
          <div class="pat-item"><span class="pat-n">[1]</span>55 41 57 41 56 41 55 41 54 53 50 49 89 fe 48 8b 1f 48 8b 43 30 4c 8b b8 d0 01 00 00 4d 85 ff 74 12 4d 8b a7 90 00 00 00 4d 85 e4...</div>
          <div class="pat-item"><span class="pat-n">[2]</span>55 41 57 41 56 41 55 41 54 53 50 49 89 f. 4c 8b 37 49 8b 46 30 4c 8b a. .. 0. 00 00 4d 85 e. 74 1. 4d 8b</div>
          <div class="pat-item"><span class="pat-n">[3]</span>55 41 57 41 56 41 55 41 54 53 48 83 EC 18 49 89 FF 48 8B 1F 48 8B 43 30 4C 8B A0 28 02 00 00 4D 85 E4 74</div>
          <div class="pat-item"><span class="pat-n">[4]</span>55 41 57 41 56 41 55 41 54 53 48 83 EC 18 49 89 FE 4C 8B 27 49 8B 44 24 30 48 8B 98 D0 01 00 00 48 85 DB</div>
          <div class="pat-item"><span class="pat-n">[5]</span>55 41 57 41 56 41 55 41 54 53 48 83 EC 38 C6 02 50 48 8B AF A. 00 00 00 48 85 ED 74 7. 48 83 7D 00 00 74</div>
        </div>
        <div id="pat-ret0" class="tab-pane" role="tabpanel">
          <div class="g3">
            <div class="ic" style="border:1px solid var(--b1)">
              <div class="ici" aria-hidden="true">💪</div><h3>arm64</h3>
              <code style="font-size:.7rem;font-family:monospace;color:var(--p2);word-break:break-all;display:block;margin-top:.3rem">00 00 80 D2 C0 03 5F D6</code>
              <p style="margin-top:.38rem">mov x0, #0<br/>ret</p>
            </div>
            <div class="ic" style="border:1px solid var(--b1)">
              <div class="ici" aria-hidden="true">💪</div><h3>arm (32-bit)</h3>
              <code style="font-size:.7rem;font-family:monospace;color:var(--p2);word-break:break-all;display:block;margin-top:.3rem">00 00 A0 E3 1E FF 2F E1</code>
              <p style="margin-top:.38rem">mov r0, #0<br/>bx lr</p>
            </div>
            <div class="ic" style="border:1px solid var(--b1)">
              <div class="ici" aria-hidden="true">💪</div><h3>x86 / x86_64</h3>
              <code style="font-size:.7rem;font-family:monospace;color:var(--p2);word-break:break-all;display:block;margin-top:.3rem">48 31 C0 C3</code>
              <p style="margin-top:.38rem">xor rax, rax<br/>ret</p>
            </div>
          </div>
        </div>
