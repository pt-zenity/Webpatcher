    </section>
  </div><!-- /mode-flutter -->

  <!-- ══════════════════════════════════════
       MODE B: APK PATCHER
  ══════════════════════════════════════ -->
  <div id="mode-apk" class="mode-content" role="tabpanel" aria-labelledby="tab-apk">
    <section class="section">
      <div class="tool-card">
        <!-- Status bar -->
        <div class="stats-bar">
          <div class="si"><div class="sd" style="background:var(--g2)" aria-hidden="true"></div><span class="sl">Status</span><span class="sv" id="srv-status-a">Online</span></div>
          <div class="si"><div class="sd" style="background:var(--org)" aria-hidden="true"></div><span class="sl">Engine</span><span class="sv">ApkPatcher</span></div>
          <div class="si"><div class="sd" style="background:var(--blue)" aria-hidden="true"></div><span class="sl">Stack</span><span class="sv">Java 21 · Apktool 2.10</span></div>
          <div class="si"><div class="sd" style="background:var(--yel)" aria-hidden="true"></div><span class="sl">Max</span><span class="sv">500 MB</span></div>
        </div>

        <!-- Header -->
        <div class="tool-header">
          <span class="th-icon" aria-hidden="true">📦</span>
          <div>
            <div class="th-title">APK Patcher — Full Patch Suite</div>
            <div class="th-sub">Upload APK → Scan → Pilih patch → Decompile → Patch Smali → Recompile → Sign → Download</div>
          </div>
        </div>

        <div class="tool-body">
          <div class="step-flow" role="list">

            <!-- STEP 1: Upload & Scan -->
            <div class="step-item" role="listitem">
              <div class="step-num" id="snum-1" aria-label="Step 1">1</div>
              <div class="step-body">
                <div class="step-title">Upload &amp; Scan APK</div>
                <div class="step-content open" id="sc-1">
                  <!-- Drop Zone APK -->
                  <div class="dropzone" id="dz-a"
                       ondragover="dzOver(this,event)" ondragleave="dzLeave(this)" ondrop="dzDrop(this,event,'a')"
                       role="button" tabindex="0" aria-label="Upload APK — drop here or click to browse"
                       onkeydown="if(event.key==='Enter'||event.key===' ')document.getElementById('file-a').click()">
                    <input type="file" id="file-a" accept=".apk,.xapk,.apkm,.apks" onchange="onPick(this,'a')"
                           tabindex="-1" aria-hidden="true"/>
                    <div class="dz-icon" aria-hidden="true">📦</div>
                    <div class="dz-title">Drop APK di sini</div>
                    <div class="dz-sub">atau tap untuk pilih file</div>
                    <div class="dz-hint">📎 .apk / .xapk / .apkm / .apks · maks 500 MB</div>
                  </div>

                  <!-- File preview APK -->
                  <div class="file-preview" id="fp-a" role="status">
                    <div class="fp-icon" aria-hidden="true">📦</div>
                    <div class="fp-info">
                      <div class="fp-name" id="fp-a-name">—</div>
                      <div class="fp-meta" id="fp-a-meta">—</div>
                    </div>
                    <button class="fp-rm" onclick="clearFile('a')" aria-label="Hapus APK" title="Hapus">✕</button>
                  </div>

                  <!-- Upload progress APK -->
                  <div id="up-prog-a" class="up-prog" role="status" aria-live="polite">
                    <div class="up-prog-label">
                      <span>Mengupload APK…</span>
                      <span id="up-pct-a">0%</span>
                    </div>
                    <div class="up-prog-bar">
                      <div class="up-prog-fill" id="up-fill-a"></div>
                    </div>
                  </div>

                  <!-- Scan button -->
                  <button class="btn btn-primary" id="btn-scan" onclick="scanApk()" disabled
                          aria-label="Scan APK untuk mendeteksi tipe dan fitur">
                    <div class="spin" aria-hidden="true"></div>
                    <span class="btn-text">🔍 Scan APK</span>
                  </button>

                  <!-- Scan result badges -->
                  <div class="scan-res" id="scan-res" role="status" aria-live="polite">
                    <div class="scan-title">📊 Hasil Scan</div>
                    <div class="scan-chips" id="scan-chips"></div>
                  </div>
                </div>
              </div>
            </div>

            <!-- STEP 2: Select patches (locked until scan done) -->
            <div class="step-item" id="step2-wrap" style="opacity:.35;pointer-events:none" aria-disabled="true">
              <div class="step-num" id="snum-2" aria-label="Step 2">2</div>
              <div class="step-body">
                <div class="step-title">Pilih Patch</div>
                <div class="step-content" id="sc-2">
                  <p class="step-sub">Centang patch yang diinginkan. Beberapa patch memerlukan kondisi APK tertentu.</p>

                  <div class="patch-grid" role="group" aria-label="Pilihan patch APK">
                    <label class="popt" id="popt-flutter">
                      <input type="checkbox" id="ck-flutter" onchange="syncPopt(this)" aria-describedby="pdesc-flutter"/>
                      <div class="popt-body">
                        <div class="popt-name">⚡ Flutter SSL Bypass <span class="pf">-f</span></div>
                        <div class="popt-desc" id="pdesc-flutter">Patch libflutter.so via radare2. Hanya berlaku jika APK Flutter.</div>
                      </div>
                    </label>
                    <label class="popt" id="popt-pairip">
                      <input type="checkbox" id="ck-pairip" onchange="syncPopt(this)" aria-describedby="pdesc-pairip"/>
                      <div class="popt-body">
                        <div class="popt-name">🔓 Pairip Bypass <span class="pf">-p</span></div>
                        <div class="popt-desc" id="pdesc-pairip">Bypass proteksi Pairip/VM. Install di VM atau Multi-App.</div>
                      </div>
                    </label>
                    <label class="popt" id="popt-pairip_corex">
                      <input type="checkbox" id="ck-pairip_corex" onchange="syncPopt(this)" aria-describedby="pdesc-corex"/>
                      <div class="popt-body">
                        <div class="popt-name">🧬 Pairip + CoreX Hook <span class="pf">-p -x</span></div>
                        <div class="popt-desc" id="pdesc-corex">Hook CoreX arm64. Lebih dalam dari Pairip biasa.</div>
                      </div>
                    </label>
                    <label class="popt" id="popt-spoof_pkg">
                      <input type="checkbox" id="ck-spoof_pkg" onchange="syncPopt(this)" aria-describedby="pdesc-spoof"/>
                      <div class="popt-body">
                        <div class="popt-name">🎭 Spoof Package <span class="pf">-pkg</span></div>
                        <div class="popt-desc" id="pdesc-spoof">Spoof deteksi package di Dex, Manifest &amp; Resources.</div>
                      </div>
                    </label>
                    <label class="popt" id="popt-remove_ads">
                      <input type="checkbox" id="ck-remove_ads" onchange="syncPopt(this)" aria-describedby="pdesc-ads"/>
                      <div class="popt-body">
                        <div class="popt-name">🚫 Remove Ads <span class="pf">-rmads</span></div>
                        <div class="popt-desc" id="pdesc-ads">Scan dan patch kode iklan dari Smali.</div>
                      </div>
                    </label>
                    <label class="popt" id="popt-remove_ss">
                      <input type="checkbox" id="ck-remove_ss" onchange="syncPopt(this)" aria-describedby="pdesc-ss"/>
                      <div class="popt-body">
                        <div class="popt-name">📸 Bypass Screenshot <span class="pf">-rmss</span></div>
                        <div class="popt-desc" id="pdesc-ss">Hapus FLAG_SECURE — izinkan screenshot &amp; rekaman layar.</div>
                      </div>
                    </label>
                    <label class="popt" id="popt-remove_usb">
                      <input type="checkbox" id="ck-remove_usb" onchange="syncPopt(this)" aria-describedby="pdesc-usb"/>
                      <div class="popt-body">
                        <div class="popt-name">🔌 Bypass USB Debug <span class="pf">-rmusb</span></div>
                        <div class="popt-desc" id="pdesc-usb">Hapus deteksi USB debugging / ADB.</div>
                      </div>
                    </label>
                    <label class="popt" id="popt-random_info">
                      <input type="checkbox" id="ck-random_info" onchange="syncPopt(this)" aria-describedby="pdesc-rnd"/>
                      <div class="popt-body">
                        <div class="popt-name">📱 Random Device Info <span class="pf">-r</span></div>
                        <div class="popt-desc" id="pdesc-rnd">Spoof info device Samsung/Xiaomi/Google secara acak.</div>
                      </div>
                    </label>
                    <label class="popt" id="popt-purchase">
                      <input type="checkbox" id="ck-purchase" onchange="syncPopt(this)" aria-describedby="pdesc-purch"/>
                      <div class="popt-body">
                        <div class="popt-name">💰 Purchase Bypass <span class="pf">-P</span></div>
                        <div class="popt-desc" id="pdesc-purch">Patch verifikasi pembelian &amp; license check.</div>
                      </div>
                    </label>
                    <label class="popt" id="popt-tg_patch">
                      <input type="checkbox" id="ck-tg_patch" onchange="syncPopt(this)" aria-describedby="pdesc-tg"/>
                      <div class="popt-body">
                        <div class="popt-name">✈️ Telegram Patch <span class="pf">-t</span></div>
                        <div class="popt-desc" id="pdesc-tg">Patch khusus untuk aplikasi Telegram.</div>
                      </div>
                    </label>
                  </div>

                  <!-- Android ID (optional) -->
                  <div class="mt" style="max-width:360px">
                    <label class="opt-label" for="aid-inp" style="display:block;font-size:.72rem;font-weight:700;color:var(--mu2);letter-spacing:.05em;text-transform:uppercase;margin-bottom:.36rem">
                      Android ID Kustom <span style="font-family:monospace;font-size:.62rem;color:var(--p2)">[-D, opsional]</span>
                    </label>
                    <input type="text" id="aid-inp" class="inp" placeholder="16 digit hex, cth: a1b2c3d4e5f60789" maxlength="16" pattern="[a-fA-F0-9]{16}" autocomplete="off" spellcheck="false"/>
                    <div class="inp-hint">Kosongkan jika tidak perlu hook Android ID tertentu.</div>
                  </div>

                  <div class="alert alert-i mt">
                    <span class="alert-ico" aria-hidden="true">ℹ️</span>
                    <div>SSL bypass di APK Patcher: <strong>Smali patching</strong> (bypass Java SSL methods) + <strong>Network Security Config</strong> (trust user certs). Berbeda dari Flutter SSL yang patch binary <code>libflutter.so</code> langsung.</div>
                  </div>

                  <!-- Patch APK button -->
                  <button class="btn btn-primary" id="btn-patch-apk" onclick="runApkPatch()" disabled
                          aria-label="Mulai patch APK dengan opsi yang dipilih">
                    <div class="spin" aria-hidden="true"></div>
                    <span class="btn-text">🚀 Patch APK Sekarang</span>
                  </button>
                </div>
              </div>
            </div>

            <!-- STEP 3: Processing & results (locked until patch started) -->
            <div class="step-item" id="step3-wrap" style="opacity:.35;pointer-events:none" aria-disabled="true">
              <div class="step-num" id="snum-3" aria-label="Step 3">3</div>
              <div class="step-body">
                <div class="step-title">Proses Patching</div>
                <div class="step-content" id="sc-3">
                  <p class="step-sub">Proses 1–5 menit tergantung ukuran APK &amp; patch dipilih. Jangan tutup browser atau refresh halaman.</p>

                  <!-- Progress -->
                  <div class="prog-wrap show" id="prog-a" role="status" aria-live="polite">
                    <div class="prog-top">
                      <span class="prog-label" id="prog-a-lbl">Menunggu…</span>
                      <span id="prog-a-pct" aria-hidden="true"></span>
                    </div>
                    <div class="prog-bg">
                      <div class="prog-fill" id="prog-a-fill" style="width:3%"></div>
                    </div>
                  </div>

                  <!-- Job status & elapsed timer -->
                  <div class="job-status-row">
                    <div class="status-pill sp-run sp-pulse" id="job-pill" role="status">⏳ Menjalankan ApkPatcher…</div>
                    <span class="elapsed" id="job-elapsed" aria-live="polite"></span>
                  </div>

                  <!-- Live log APK -->
                  <div class="log-panel show" id="log-a" style="margin-top:.88rem" role="log" aria-label="Live log APK patching" aria-live="polite">
                    <div class="log-head">
                      <span class="log-title-txt">
                        <span class="log-live-dot" id="log-a-dot" aria-hidden="true"></span>
                        📋 Live Log
                        <span class="log-count" id="log-a-cnt" aria-label="log lines count">0</span>
                      </span>
                      <div class="log-actions">
                        <button class="log-btn" onclick="scrollLog('a')" aria-label="Scroll ke bawah log">↓ Bawah</button>
                        <button class="log-btn" onclick="copyLog('a')" aria-label="Salin semua log">📋 Copy</button>
                        <button class="log-btn" onclick="clearLog('a')" aria-label="Hapus log">🗑 Clear</button>
                      </div>
                    </div>
                    <div class="log-body" id="log-a-body"></div>
                  </div>

                  <!-- APK Result -->
                  <div class="result-panel" id="result-a" role="status" aria-live="polite"></div>

                  <!-- Reset button (shown after done) -->
                  <div id="apk-reset-row" class="hidden" style="margin-top:.8rem">
                    <button class="btn btn-sec" onclick="resetApk()">🔄 Patch APK Lain</button>
                  </div>
