            </div>

          </div><!-- /step-flow -->
        </div><!-- /tool-body -->
      </div><!-- /tool-card -->
    </section>

    <!-- About ApkPatcher -->
    <section class="section">
      <div class="section-title">📖 Fitur &amp; Stack ApkPatcher</div>
      <div class="g2">
        <div class="tool-card">
          <div style="padding:1.05rem">
            <div class="section-title" style="font-size:.88rem;margin-bottom:.75rem">🛠️ Patch yang Tersedia</div>
            <table class="feat-table">
              <thead><tr><th>Patch</th><th>Fungsi</th></tr></thead>
              <tbody>
                <tr><td><span class="tick">✅</span> Flutter SSL</td><td>patch libflutter.so via r2</td></tr>
