def check_dependencies():
    try:
        M.subprocess.run(['java', '-version'], stdout=M.subprocess.PIPE, stderr=M.subprocess.PIPE, check=True, text=True)
    except (M.subprocess.CalledProcessError, FileNotFoundError):
        print(f"{C.ERROR} Java is not installed on Your System.  ✘")
        print(f"{C.INFO} Install Java: sudo apt install -y openjdk-21-jdk")
        # Don't exit — java might be in a non-standard PATH, continue

    # aapt check — on Ubuntu it's installed via apt, not pkg
    try:
        M.subprocess.run(['aapt', 'version'], stdout=M.subprocess.PIPE, stderr=M.subprocess.PIPE, check=True, text=True)
    except (M.subprocess.CalledProcessError, FileNotFoundError):
        print(f"{C.INFO} aapt not found, trying to install via apt...")
        try:
            M.subprocess.run(['apt-get', 'install', '-y', 'aapt'], check=True,
                             stdout=M.subprocess.PIPE, stderr=M.subprocess.PIPE)
        except Exception:
            pass  # Continue even if install fails


